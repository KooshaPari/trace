# TraceRTM Backend Configuration with Neo4j

# Server
PORT=8080
ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/tracertm

# JWT
JWT_SECRET=your-secret-key-change-in-production

# NATS
NATS_URL=nats://localhost:4222
NATS_CREDS=

# Redis
REDIS_URL=redis://localhost:6379

# Neo4j - Local Development
NEO4J_URI=neo4j://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Neo4j - Production (Neo4j Aura)
# NEO4J_URI=neo4j+s://your-aura-host:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=your-aura-password

# Embeddings
EMBEDDING_PROVIDER=voyage
VOYAGE_API_KEY=your-voyage-api-key
VOYAGE_MODEL=voyage-3.5
VOYAGE_DIMENSIONS=1024

# Reranking
RERANK_ENABLED=true
RERANK_MODEL=rerank-2.5

# Performance
EMBEDDING_RATE_LIMIT=300
EMBEDDING_TIMEOUT=60
EMBEDDING_MAX_RETRIES=3
EMBEDDING_BATCH_SIZE=128

# Indexer
INDEXER_ENABLED=true
INDEXER_WORKERS=3
INDEXER_BATCH_SIZE=50
INDEXER_POLL_INTERVAL=30

