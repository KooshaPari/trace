# TraceRTM Environment Variables
# Copy this file to .env and update with your local settings
# All variables are optional and will use defaults from settings.yml

# Project Settings
# TRACERTM_CURRENT_PROJECT_ID=project-123
# TRACERTM_CURRENT_PROJECT_NAME=My Project

# Display Preferences
# TRACERTM_DEFAULT_VIEW=FEATURE
# TRACERTM_OUTPUT_FORMAT=json

# Performance Settings
# TRACERTM_MAX_AGENTS=1000
# TRACERTM_CACHE_TTL=300
# TRACERTM_BATCH_SIZE=100

# Logging Configuration
# TRACERTM_LOG_LEVEL=DEBUG
# TRACERTM_LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Database Configuration (nested with __)
# For PostgreSQL (production):
# TRACERTM_DATABASE__URL=postgresql://user:password@localhost:5432/tracertm
# For SQLite (development):
# TRACERTM_DATABASE__URL=sqlite:///tracertm.db
# TRACERTM_DATABASE__ECHO=false
# TRACERTM_DATABASE__POOL_SIZE=10
# TRACERTM_DATABASE__MAX_OVERFLOW=20

# Feature Flags
# TRACERTM_ENABLE_CACHE=true
# TRACERTM_ENABLE_ASYNC=true
# TRACERTM_ENABLE_VALIDATION=true

# Development Settings
# TRACERTM_LOG_LEVEL=DEBUG
# TRACERTM_DATABASE__ECHO=true

