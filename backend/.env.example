# ==============================================================================
# GO BACKEND ENVIRONMENT VARIABLES - TEMPLATE
# ==============================================================================
# Copy this file to .env and fill in your actual values
# Note: Also loads variables from root .env
# ==============================================================================

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
PORT=8080
GRPC_PORT=9090
ENV=development
GIN_MODE=debug

# -----------------------------------------------------------------------------
# Database (Go Format - postgres:// instead of postgresql+asyncpg://)
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://tracertm:YOUR_DB_PASSWORD@localhost:5432/tracertm?sslmode=disable

# Test database URL (used by Go tests)
# Use same database with tracertm_password for local testing
TEST_DATABASE_URL=postgres://tracertm:tracertm_password@localhost:5432/tracertm?sslmode=disable

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Generate with: openssl rand -hex 32
CSRF_SECRET=YOUR_RANDOM_32_BYTE_HEX_STRING

# JWT Configuration (shared with Python backend)
JWT_SECRET=YOUR_RANDOM_32_BYTE_HEX_STRING
JWT_EXPIRY=24h

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# -----------------------------------------------------------------------------
# Rate Limiting Configuration
# -----------------------------------------------------------------------------
# Authentication endpoints (per IP address)
RATE_LIMIT_AUTH_RPM=5          # Requests per minute for /api/v1/auth/*

# API endpoints (per user if authenticated, per IP otherwise)
RATE_LIMIT_API_RPM=100         # Requests per minute for /api/v1/*

# Static assets (per IP)
RATE_LIMIT_STATIC_RPM=1000     # Requests per minute for /static/* and /assets/*

# Rate limiter cleanup settings
RATE_LIMITER_TTL_SECONDS=300           # 5 minutes - TTL for in-memory limiters
RATE_LIMITER_CLEANUP_INTERVAL_SECONDS=60  # 1 minute - cleanup frequency

# -----------------------------------------------------------------------------
# NATS Configuration
# -----------------------------------------------------------------------------
NATS_URL=nats://localhost:4222

# For NATS Cloud (NGS):
# NATS_URL=nats://connect.ngs.global:4222
# NATS_CREDS=/path/to/your/ngs-credentials.creds

# -----------------------------------------------------------------------------
# WorkOS AuthKit Configuration
# -----------------------------------------------------------------------------
# Get these from: https://dashboard.workos.com/
WORKOS_CLIENT_ID=client_XXXXXXXXXX
WORKOS_API_KEY=sk_test_XXXXXXXXXX
WORKOS_API_BASE_URL=https://api.workos.com
WORKOS_JWKS_URL=https://api.workos.com/sso/jwks/${WORKOS_CLIENT_ID}
WORKOS_JWT_ISSUER=https://api.workos.com/
WORKOS_JWT_AUDIENCE=${WORKOS_CLIENT_ID}

# WorkOS Test User Setup
# Organization ID for test user creation
# Get from: https://dashboard.workos.com/organizations
WORKOS_ORG_ID=org_XXXXXXXXXX

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins (no wildcards in production)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# -----------------------------------------------------------------------------
# Object Storage (S3-Compatible - Optional)
# -----------------------------------------------------------------------------
# Local MinIO (docker run -p 9000:9000 -p 9001:9001 minio/minio server /data)
S3_ENDPOINT=http://127.0.0.1:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=tracertm
S3_REGION=us-east-1

# Cloud Storage (AWS S3, Cloudflare R2, etc.)
# S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
# S3_ACCESS_KEY_ID=your_access_key
# S3_SECRET_ACCESS_KEY=your_secret_key
# S3_BUCKET=your-bucket-name
# S3_REGION=auto

# -----------------------------------------------------------------------------
# Cross-Backend Communication
# -----------------------------------------------------------------------------
PYTHON_BACKEND_URL=http://localhost:8000
SERVICE_TOKEN=YOUR_SHARED_SERVICE_TOKEN

# -----------------------------------------------------------------------------
# GitHub App Integration (Optional)
# -----------------------------------------------------------------------------
# Get these from: https://github.com/settings/apps
GITHUB_APP_ID=YOUR_APP_ID
GITHUB_APP_CLIENT_ID=Iv_XXXXXXXXXX
GITHUB_APP_CLIENT_SECRET=YOUR_CLIENT_SECRET
GITHUB_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET
GITHUB_PRIVATE_KEY_PATH=/path/to/your/github-app-private-key.pem

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
ENABLE_WEBSOCKET=true
ENABLE_EVENTS=true
ENABLE_SEARCH=true
ENABLE_VECTOR_SEARCH=true
ENABLE_NATS=true
ENABLE_REDIS_CACHE=true

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# Observability - Distributed Tracing
# -----------------------------------------------------------------------------
# Enable/disable tracing
TRACING_ENABLED=true

# Jaeger OTLP endpoint (default: localhost:4317)
JAEGER_ENDPOINT=127.0.0.1:4317

# Environment name for tracing (development, staging, production)
TRACING_ENVIRONMENT=development
