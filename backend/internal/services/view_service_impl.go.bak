package services

import (
	"context"
	"encoding/json"
	"fmt"
	"strings"
	"time"

	"github.com/google/uuid"
	"github.com/kooshapari/tracertm-backend/internal/cache"
	"github.com/kooshapari/tracertm-backend/internal/models"
	"github.com/kooshapari/tracertm-backend/internal/repository"
	"github.com/nats-io/nats.go"
)

// Ensure ViewServiceImpl implements ViewService
var _ ViewService = (*ViewServiceImpl)(nil)

// ViewServiceImpl implements the ViewService interface
type ViewServiceImpl struct {
	viewRepo repository.ViewRepository
	cache    cache.Cache
	natsConn *nats.Conn
	cacheTTL time.Duration
}

// NewViewServiceImpl creates a new view service implementation
func NewViewServiceImpl(
	viewRepo repository.ViewRepository,
	cache cache.Cache,
	natsConn *nats.Conn,
) ViewService {
	if viewRepo == nil {
		panic("viewRepo cannot be nil")
	}

	return &ViewServiceImpl{
		viewRepo: viewRepo,
		cache:    cache,
		natsConn: natsConn,
		cacheTTL: 5 * time.Minute,
	}
}

// ============================================================================
// View CRUD Operations
// ============================================================================

// CreateView creates a new view with validation
func (s *ViewServiceImpl) CreateView(ctx context.Context, view *models.View) error {
	// Validate view
	if err := s.ValidateView(view); err != nil {
		return fmt.Errorf("validation failed: %w", err)
	}

	// Set ID and timestamps if not set
	if view.ID == "" {
		view.ID = uuid.New().String()
	}
	now := time.Now()
	if view.CreatedAt.IsZero() {
		view.CreatedAt = now
	}
	view.UpdatedAt = now

	// Create view in repository
	if err := s.viewRepo.Create(ctx, view); err != nil {
		return fmt.Errorf("failed to create view: %w", err)
	}

	// Invalidate project cache
	if s.cache != nil {
		cacheKey := fmt.Sprintf("views:project:%s", view.ProjectID)
		_ = s.cache.Delete(ctx, cacheKey)
		_ = s.cache.Delete(ctx, "views:all")
	}

	// Publish event
	s.publishViewEvent(ctx, "view.created", view)

	return nil
}

// GetView retrieves a view by ID
func (s *ViewServiceImpl) GetView(ctx context.Context, id string) (*models.View, error) {
	if id == "" {
		return nil, fmt.Errorf("view ID cannot be empty")
	}

	// Try cache first
	if s.cache != nil {
		cacheKey := fmt.Sprintf("view:%s", id)
		if cached, err := s.cache.Get(ctx, cacheKey); err == nil && cached != "" {
			var view View
			if err := json.Unmarshal([]byte(cached), &view); err == nil {
				return &view, nil
			}
		}
	}

	// Get from repository
	view, err := s.viewRepo.GetByID(ctx, id)
	if err != nil {
		return nil, fmt.Errorf("failed to get view: %w", err)
	}

	// Cache the result
	if s.cache != nil {
		cacheKey := fmt.Sprintf("view:%s", id)
		if data, err := json.Marshal(view); err == nil {
			_ = s.cache.Set(ctx, cacheKey, string(data), s.cacheTTL)
		}
	}

	return view, nil
}

// GetViewsByProject retrieves all views for a project
func (s *ViewServiceImpl) GetViewsByProject(ctx context.Context, projectID string) ([]*models.View, error) {
	if projectID == "" {
		return nil, fmt.Errorf("project ID cannot be empty")
	}

	// Try cache first
	if s.cache != nil {
		cacheKey := fmt.Sprintf("views:project:%s", projectID)
		if cached, err := s.cache.Get(ctx, cacheKey); err == nil && cached != "" {
			var views []*models.View
			if err := json.Unmarshal([]byte(cached), &views); err == nil {
				return views, nil
			}
		}
	}

	// Get from repository
	views, err := s.viewRepo.GetByProjectID(ctx, projectID)
	if err != nil {
		return nil, fmt.Errorf("failed to get views by project: %w", err)
	}

	// Cache the result
	if s.cache != nil {
		cacheKey := fmt.Sprintf("views:project:%s", projectID)
		if data, err := json.Marshal(views); err == nil {
			_ = s.cache.Set(ctx, cacheKey, string(data), s.cacheTTL)
		}
	}

	return views, nil
}

// ListViews lists all views
func (s *ViewServiceImpl) ListViews(ctx context.Context) ([]*models.View, error) {
	// Try cache first
	if s.cache != nil {
		cacheKey := "views:all"
		if cached, err := s.cache.Get(ctx, cacheKey); err == nil && cached != "" {
			var views []*models.View
			if err := json.Unmarshal([]byte(cached), &views); err == nil {
				return views, nil
			}
		}
	}

	// Get from repository
	views, err := s.viewRepo.List(ctx)
	if err != nil {
		return nil, fmt.Errorf("failed to list views: %w", err)
	}

	// Cache the result
	if s.cache != nil {
		cacheKey := "views:all"
		if data, err := json.Marshal(views); err == nil {
			_ = s.cache.Set(ctx, cacheKey, string(data), s.cacheTTL)
		}
	}

	return views, nil
}

// UpdateView updates a view
func (s *ViewServiceImpl) UpdateView(ctx context.Context, view *models.View) error {
	if view == nil {
		return fmt.Errorf("view cannot be nil")
	}

	// Validate view
	if err := s.ValidateView(view); err != nil {
		return fmt.Errorf("validation failed: %w", err)
	}

	// Check if view exists
	existing, err := s.viewRepo.GetByID(ctx, view.ID)
	if err != nil {
		return fmt.Errorf("view not found: %w", err)
	}

	// Update timestamp
	view.UpdatedAt = time.Now()
	view.CreatedAt = existing.CreatedAt // Preserve original creation time

	// Update in repository
	if err := s.viewRepo.Update(ctx, view); err != nil {
		return fmt.Errorf("failed to update view: %w", err)
	}

	// Invalidate caches
	if s.cache != nil {
		_ = s.cache.Delete(ctx, fmt.Sprintf("view:%s", view.ID))
		_ = s.cache.Delete(ctx, fmt.Sprintf("views:project:%s", view.ProjectID))
		_ = s.cache.Delete(ctx, "views:all")
		_ = s.cache.Delete(ctx, fmt.Sprintf("view:stats:%s", view.ID))
	}

	// Publish event
	s.publishViewEvent(ctx, "view.updated", view)

	return nil
}

// DeleteView deletes a view
func (s *ViewServiceImpl) DeleteView(ctx context.Context, id string) error {
	if id == "" {
		return fmt.Errorf("view ID cannot be empty")
	}

	// Get view to get project ID for cache invalidation
	view, err := s.viewRepo.GetByID(ctx, id)
	if err != nil {
		return fmt.Errorf("view not found: %w", err)
	}

	// Delete from repository
	if err := s.viewRepo.Delete(ctx, id); err != nil {
		return fmt.Errorf("failed to delete view: %w", err)
	}

	// Invalidate caches
	if s.cache != nil {
		_ = s.cache.Delete(ctx, fmt.Sprintf("view:%s", id))
		_ = s.cache.Delete(ctx, fmt.Sprintf("views:project:%s", view.ProjectID))
		_ = s.cache.Delete(ctx, "views:all")
		_ = s.cache.Delete(ctx, fmt.Sprintf("view:stats:%s", id))
	}

	// Publish event
	s.publishViewEvent(ctx, "view.deleted", view)

	return nil
}

// ============================================================================
// View Statistics
// ============================================================================

// GetViewStats returns statistics for a view
func (s *ViewServiceImpl) GetViewStats(ctx context.Context, viewID string) (*models.ViewStats, error) {
	if viewID == "" {
		return nil, fmt.Errorf("view ID cannot be empty")
	}

	// Try cache first
	if s.cache != nil {
		cacheKey := fmt.Sprintf("view:stats:%s", viewID)
		if cached, err := s.cache.Get(ctx, cacheKey); err == nil && cached != "" {
			var stats ViewStats
			if err := json.Unmarshal([]byte(cached), &stats); err == nil {
				return &stats, nil
			}
		}
	}

	// Verify view exists
	view, err := s.viewRepo.GetByID(ctx, viewID)
	if err != nil {
		return nil, fmt.Errorf("view not found: %w", err)
	}

	// Get item count
	itemCount, err := s.viewRepo.CountItemsByView(ctx, viewID)
	if err != nil {
		return nil, fmt.Errorf("failed to count items: %w", err)
	}

	stats := &ViewStats{
		ViewID:    viewID,
		ItemCount: itemCount,
		UpdatedAt: view.UpdatedAt,
	}

	// Cache the result
	if s.cache != nil {
		cacheKey := fmt.Sprintf("view:stats:%s", viewID)
		if data, err := json.Marshal(stats); err == nil {
			_ = s.cache.Set(ctx, cacheKey, string(data), s.cacheTTL)
		}
	}

	return stats, nil
}

// ============================================================================
// Validation
// ============================================================================

// ValidateView validates view business rules
func (s *ViewServiceImpl) ValidateView(view *models.View) error {
	if view == nil {
		return fmt.Errorf("view cannot be nil")
	}

	// Validate required fields
	if view.Name == "" {
		return fmt.Errorf("view name is required")
	}

	if view.ProjectID == "" {
		return fmt.Errorf("project ID is required")
	}

	if view.Type == "" {
		return fmt.Errorf("view type is required")
	}

	// Validate name length
	if len(view.Name) > 200 {
		return fmt.Errorf("view name cannot exceed 200 characters")
	}

	// Validate view type
	validTypes := map[string]bool{
		"kanban":   true,
		"timeline": true,
		"matrix":   true,
		"graph":    true,
		"table":    true,
		"board":    true,
		"list":     true,
	}

	if !validTypes[view.Type] {
		return fmt.Errorf("invalid view type: %s (must be one of: kanban, timeline, matrix, graph, table, board, list)", view.Type)
	}

	// Validate config is valid JSON if provided
	if view.Config != "" {
		var config map[string]interface{}
		if err := json.Unmarshal([]byte(view.Config), &config); err != nil {
			return fmt.Errorf("invalid config JSON: %w", err)
		}
	}

	return nil
}

// ============================================================================
// Event Publishing
// ============================================================================

// publishViewEvent publishes a view event to NATS
func (s *ViewServiceImpl) publishViewEvent(ctx context.Context, eventType string, view *models.View) {
	if s.natsConn == nil {
		return
	}

	event := map[string]interface{}{
		"type":       eventType,
		"view_id":    view.ID,
		"project_id": view.ProjectID,
		"view_type":  view.Type,
		"timestamp":  time.Now().Format(time.RFC3339),
	}

	if data, err := json.Marshal(event); err == nil {
		subject := strings.ReplaceAll(eventType, ".", "_")
		_ = s.natsConn.Publish(subject, data)
	}
}
