		},
	}

	e := setupAuthMeServer(t, stub)
	req := httptest.NewRequest(http.MethodGet, "/api/v1/auth/me", nil)
	req.Header.Set("Authorization", "Bearer bad-token")
	rec := httptest.NewRecorder()

	e.ServeHTTP(rec, req)

	assert.Equal(t, http.StatusUnauthorized, rec.Code)
}

// TestAuthMiddleware_ValidToken_Success verifies that a valid token allows access
func TestAuthMiddleware_ValidToken_Success(t *testing.T) {
	expectedUser := &auth.User{
		ID:        "user-456",
		Email:     "success@example.com",
		Name:      "Success User",
		Role:      "admin",
		ProjectID: "project-2",
		Metadata:  map[string]interface{}{"level": "premium"},
	}

	stub := &stubAuthProvider{
		validateFn: func(ctx context.Context, token string) (*auth.User, error) {
			if token == "valid-token-123" {
				return expectedUser, nil
			}
			return nil, errors.New("invalid token")
		},
	}

	e := setupProtectedRoute(t, stub)
	req := httptest.NewRequest(http.MethodGet, "/api/v1/protected", nil)
	req.Header.Set("Authorization", "Bearer valid-token-123")
	rec := httptest.NewRecorder()

	e.ServeHTTP(rec, req)

	require.Equal(t, http.StatusOK, rec.Code)

	var response map[string]interface{}
	require.NoError(t, json.NewDecoder(rec.Body).Decode(&response))

	assert.Equal(t, "protected resource", response["message"])
	assert.NotNil(t, response["user"])
}

