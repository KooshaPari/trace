// TestAuthMiddleware_TokenValidation_Success verifies token validation flow
func TestAuthMiddleware_TokenValidation_Success(t *testing.T) {
	validationCalled := false
	expectedUser := &auth.User{
		ID:        "validation-user",
		Email:     "validate@example.com",
		Name:      "Validation User",
		Role:      "user",
		ProjectID: "project-val",
	}

	stub := &stubAuthProvider{
		validateFn: func(ctx context.Context, token string) (*auth.User, error) {
			validationCalled = true
			assert.Equal(t, "token-to-validate", token)
			return expectedUser, nil
		},
	}

	e := setupProtectedRoute(t, stub)
	req := httptest.NewRequest(http.MethodGet, "/api/v1/protected", nil)
	req.Header.Set("Authorization", "Bearer token-to-validate")
	rec := httptest.NewRecorder()

	e.ServeHTTP(rec, req)

	assert.Equal(t, http.StatusOK, rec.Code)
	assert.True(t, validationCalled, "validation function should have been called")
}

// TestAuthMiddleware_ClaimsExtraction_Success verifies that user claims are correctly extracted and set in context
func TestAuthMiddleware_ClaimsExtraction_Success(t *testing.T) {
	expectedUser := &auth.User{
		ID:        "claims-user",
		Email:     "claims@example.com",
		Name:      "Claims User",
		Role:      "manager",
		ProjectID: "project-claims",
		Metadata: map[string]interface{}{
			"department": "engineering",
			"level":      5,
		},
	}

	stub := &stubAuthProvider{
		validateFn: func(ctx context.Context, token string) (*auth.User, error) {
			return expectedUser, nil
		},
	}

	e := echo.New()
	api := e.Group("/api/v1")
	api.Use(AuthAdapterMiddleware(AuthAdapterConfig{
		AuthProvider: stub,
	}))
	api.GET("/claims-test", func(c echo.Context) error {
		// Verify context values
		user := c.Get("user")
		userID := c.Get("user_id")
		userEmail := c.Get("user_email")
		projectID := c.Get("project_id")
		role := c.Get("role")

		return c.JSON(http.StatusOK, map[string]interface{}{
			"user":       user,
			"user_id":    userID,
			"user_email": userEmail,
			"project_id": projectID,
			"role":       role,
		})
	})

	req := httptest.NewRequest(http.MethodGet, "/api/v1/claims-test", nil)
	req.Header.Set("Authorization", "Bearer valid-token")
	rec := httptest.NewRecorder()

	e.ServeHTTP(rec, req)

	require.Equal(t, http.StatusOK, rec.Code)

	var response map[string]interface{}
	require.NoError(t, json.NewDecoder(rec.Body).Decode(&response))

	assert.Equal(t, expectedUser.ID, response["user_id"])
	assert.Equal(t, expectedUser.Email, response["user_email"])
	assert.Equal(t, expectedUser.ProjectID, response["project_id"])
	assert.Equal(t, expectedUser.Role, response["role"])
}

