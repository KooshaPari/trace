// stubAuthProvider is a lightweight AuthProvider implementation used only in tests.
// It allows us to exercise AuthAdapterMiddleware and the /api/v1/auth/me handler
// without depending on external services like Supabase or AuthKit.
type stubAuthProvider struct {
	validateFn   func(ctx context.Context, token string) (*auth.User, error)
	getUserFn    func(ctx context.Context, userID string) (*auth.User, error)
	createUserFn func(ctx context.Context, email, password, name string) (*auth.User, error)
	updateUserFn func(ctx context.Context, userID string, updates map[string]interface{}) (*auth.User, error)
	deleteUserFn func(ctx context.Context, userID string) error
	listUsersFn  func(ctx context.Context, limit, offset int) ([]*auth.User, error)
}

func (s *stubAuthProvider) ValidateToken(ctx context.Context, token string) (*auth.User, error) {
	if s.validateFn != nil {
		return s.validateFn(ctx, token)
	}
	return nil, errors.New("not implemented")
}

func (s *stubAuthProvider) GetUser(ctx context.Context, userID string) (*auth.User, error) {
	if s.getUserFn != nil {
		return s.getUserFn(ctx, userID)
	}
	return nil, errors.New("not implemented")
}

func (s *stubAuthProvider) CreateUser(ctx context.Context, email, password, name string) (*auth.User, error) {
	if s.createUserFn != nil {
		return s.createUserFn(ctx, email, password, name)
	}
	return nil, errors.New("not implemented")
}

func (s *stubAuthProvider) UpdateUser(ctx context.Context, userID string, updates map[string]interface{}) (*auth.User, error) {
	if s.updateUserFn != nil {
		return s.updateUserFn(ctx, userID, updates)
	}
	return nil, errors.New("not implemented")
}

func (s *stubAuthProvider) DeleteUser(ctx context.Context, userID string) error {
	if s.deleteUserFn != nil {
		return s.deleteUserFn(ctx, userID)
	}
	return errors.New("not implemented")
}

func (s *stubAuthProvider) ListUsers(ctx context.Context, limit, offset int) ([]*auth.User, error) {
	if s.listUsersFn != nil {
		return s.listUsersFn(ctx, limit, offset)
	}
	return nil, errors.New("not implemented")
}

func (s *stubAuthProvider) Close() error { return nil }

// setupAuthMeServer wires a minimal Echo instance with AuthAdapterMiddleware and
// the /api/v1/auth/me route, using the provided AuthProvider.
func setupAuthMeServer(t *testing.T, provider auth.AuthProvider) *echo.Echo {
	t.Helper()

	e := echo.New()
	api := e.Group("/api/v1")
	api.Use(AuthAdapterMiddleware(AuthAdapterConfig{
		AuthProvider: provider,
	})))
	api.GET("/auth/me", handlers.AuthMe)

	return e
}

// setupProtectedRoute creates a minimal Echo instance with a protected route
func setupProtectedRoute(t *testing.T, provider auth.AuthProvider) *echo.Echo {
	t.Helper()

	e := echo.New()
	api := e.Group("/api/v1")
	api.Use(AuthAdapterMiddleware(AuthAdapterConfig{
		AuthProvider: provider,
	}))
	api.GET("/protected", func(c echo.Context) error {
		user := c.Get("user")
		if user == nil {
			return echo.NewHTTPError(http.StatusUnauthorized, "user not found in context")
		}
		return c.JSON(http.StatusOK, map[string]interface{}{
			"message": "protected resource",
			"user":    user,
		})
	})

	return e
}

// TestAuthAdapterMiddleware_AuthMe_UnauthorizedWithoutToken verifies that
// requests without an Authorization header receive 401 from /api/v1/auth/me.
func TestAuthAdapterMiddleware_AuthMe_UnauthorizedWithoutToken(t *testing.T) {
	stub := &stubAuthProvider{
		validateFn: func(ctx context.Context, token string) (*auth.User, error) {
			return nil, errors.New("should not be called")
		},
	}

	e := setupAuthMeServer(t, stub)
	req := httptest.NewRequest(http.MethodGet, "/api/v1/auth/me", nil)
	rec := httptest.NewRecorder()

	e.ServeHTTP(rec, req)

	assert.Equal(t, http.StatusUnauthorized, rec.Code)
}

// TestAuthAdapterMiddleware_AuthMe_ReturnsCurrentUser verifies that a valid
// Bearer token is validated by the adapter and the current user is returned
// from /api/v1/auth/me.
func TestAuthAdapterMiddleware_AuthMe_ReturnsCurrentUser(t *testing.T) {
	expectedUser := &auth.User{
		ID:        "user-123",
		Email:     "user@example.com",
		Name:      "Test User",
		Role:      "user",
		ProjectID: "project-1",
		Metadata:  map[string]interface{}{"source": "test"},
	}

	stub := &stubAuthProvider{
		validateFn: func(ctx context.Context, token string) (*auth.User, error) {
			if token != "valid-token" {
				return nil, errors.New("invalid token")
			}
			return expectedUser, nil
		},
	}

	e := setupAuthMeServer(t, stub)
	req := httptest.NewRequest(http.MethodGet, "/api/v1/auth/me", nil)
	req.Header.Set("Authorization", "Bearer valid-token")
	rec := httptest.NewRecorder()

	e.ServeHTTP(rec, req)

	require.Equal(t, http.StatusOK, rec.Code)

	var got auth.User
	require.NoError(t, json.NewDecoder(rec.Body).Decode(&got))

	assert.Equal(t, expectedUser.ID, got.ID)
	assert.Equal(t, expectedUser.Email, got.Email)
	assert.Equal(t, expectedUser.ProjectID, got.ProjectID)
}

// TestAuthAdapterMiddleware_AuthMe_InvalidToken verifies that an invalid token
// results in a 401 Unauthorized response from /api/v1/auth/me.
func TestAuthAdapterMiddleware_AuthMe_InvalidToken(t *testing.T) {
	stub := &stubAuthProvider{
