// TestAuthMiddleware_RateLimiting_Allowed verifies that requests within rate limit are allowed
func TestAuthMiddleware_RateLimiting_Allowed(t *testing.T) {
	stub := &stubAuthProvider{
		validateFn: func(ctx context.Context, token string) (*auth.User, error) {
			return &auth.User{ID: "rate-user", Email: "rate@example.com"}, nil
		},
	}

	e := echo.New()
	api := e.Group("/api/v1")

	// Add rate limiting with high limits
	rateLimiter := NewRateLimitMiddleware(RateLimitMiddlewareConfig{
		RedisClient:             nil, // Use in-memory limiter
		AuthenticatedUserLimit:  100,
		AuthenticatedUserWindow: 60,
	})

	api.Use(AuthAdapterMiddleware(AuthAdapterConfig{
		AuthProvider: stub,
	}))

	api.GET("/rate-test", func(c echo.Context) error {
		return c.JSON(http.StatusOK, map[string]string{"status": "ok"})
	})

	// Send multiple requests - should all succeed
	for i := 0; i < 5; i++ {
		req := httptest.NewRequest(http.MethodGet, "/api/v1/rate-test", nil)
		req.Header.Set("Authorization", "Bearer valid-token")
		rec := httptest.NewRecorder()

		e.ServeHTTP(rec, req)
		assert.Equal(t, http.StatusOK, rec.Code, "Request %d should succeed", i+1)
	}
}

// TestAuthMiddleware_RateLimiting_Exceeded verifies that rate limit is enforced
func TestAuthMiddleware_RateLimiting_Exceeded(t *testing.T) {
	stub := &stubAuthProvider{
		validateFn: func(ctx context.Context, token string) (*auth.User, error) {
			return &auth.User{ID: "rate-user", Email: "rate@example.com"}, nil
		},
	}

	e := echo.New()
	api := e.Group("/api/v1")

	// Add rate limiting with very low limits
	rateLimiter := NewRateLimitMiddleware(RateLimitMiddlewareConfig{
		RedisClient:       nil, // Use in-memory limiter
		RequestsPerSecond: 0.1, // Very low rate
		BurstSize:         2,   // Allow only 2 requests
	})

	api.Use(AuthAdapterMiddleware(AuthAdapterConfig{
		AuthProvider: stub,
	}))

	api.GET("/rate-test", func(c echo.Context) error {
		return c.JSON(http.StatusOK, map[string]string{"status": "ok"})
	})

	// First 2 requests should succeed (burst)
	for i := 0; i < 2; i++ {
		req := httptest.NewRequest(http.MethodGet, "/api/v1/rate-test", nil)
		req.Header.Set("Authorization", "Bearer valid-token")
		rec := httptest.NewRecorder()

		e.ServeHTTP(rec, req)
		assert.Equal(t, http.StatusOK, rec.Code, "Request %d should succeed", i+1)
	}

	// Third request should be rate limited
	req := httptest.NewRequest(http.MethodGet, "/api/v1/rate-test", nil)
	req.Header.Set("Authorization", "Bearer valid-token")
	rec := httptest.NewRecorder()

	e.ServeHTTP(rec, req)
	assert.Equal(t, http.StatusTooManyRequests, rec.Code)
}

// TestAuthMiddleware_CORS_Handling verifies CORS headers are properly set
func TestAuthMiddleware_CORS_Handling(t *testing.T) {
	stub := &stubAuthProvider{
		validateFn: func(ctx context.Context, token string) (*auth.User, error) {
			return &auth.User{ID: "cors-user", Email: "cors@example.com"}, nil
		},
	}

	e := echo.New()

	// Add CORS middleware
	corsConfig := CORSConfig()
	e.Use(echo.MiddlewareFunc(func(next echo.HandlerFunc) echo.HandlerFunc {
		return func(c echo.Context) error {
			// Apply CORS headers
			if origin := c.Request().Header.Get("Origin"); origin != "" {
				c.Response().Header().Set("Access-Control-Allow-Origin", origin)
				c.Response().Header().Set("Access-Control-Allow-Methods", "GET, POST, PUT, PATCH, DELETE, OPTIONS")
				c.Response().Header().Set("Access-Control-Allow-Headers", "Accept, Authorization, Content-Type")
				c.Response().Header().Set("Access-Control-Allow-Credentials", "true")
			}

			if c.Request().Method == "OPTIONS" {
				return c.NoContent(http.StatusNoContent)
			}

			return next(c)
		}
	})

	api := e.Group("/api/v1")
	api.Use(AuthAdapterMiddleware(AuthAdapterConfig{
		AuthProvider: stub,
	}))
	api.GET("/cors-test", func(c echo.Context) error {
		return c.JSON(http.StatusOK, map[string]string{"status": "ok"})
	})

	// Test OPTIONS request
	req := httptest.NewRequest(http.MethodOptions, "/api/v1/cors-test", nil)
	req.Header.Set("Origin", "https://example.com")
	rec := httptest.NewRecorder()

	e.ServeHTTP(rec, req)

	assert.Equal(t, http.StatusNoContent, rec.Code)
	assert.Equal(t, "https://example.com", rec.Header().Get("Access-Control-Allow-Origin"))
	assert.Contains(t, rec.Header().Get("Access-Control-Allow-Methods"), "GET")
	assert.NotEmpty(t, corsConfig.AllowOrigins)
}

// TestAuthMiddleware_SecurityHeaders verifies security headers are properly set
func TestAuthMiddleware_SecurityHeaders(t *testing.T) {
	stub := &stubAuthProvider{
		validateFn: func(ctx context.Context, token string) (*auth.User, error) {
			return &auth.User{ID: "security-user", Email: "security@example.com"}, nil
		},
	}

	e := echo.New()

	// Add security headers middleware
	e.Use(SecurityHeaders())

	api := e.Group("/api/v1")
	api.Use(AuthAdapterMiddleware(AuthAdapterConfig{
		AuthProvider: stub,
	}))
	api.GET("/security-test", func(c echo.Context) error {
		return c.JSON(http.StatusOK, map[string]string{"status": "ok"})
	})

	req := httptest.NewRequest(http.MethodGet, "/api/v1/security-test", nil)
	req.Header.Set("Authorization", "Bearer valid-token")
	rec := httptest.NewRecorder()

	e.ServeHTTP(rec, req)

	assert.Equal(t, http.StatusOK, rec.Code)

	// Verify security headers
	headers := rec.Header()
	assert.Equal(t, "nosniff", headers.Get("X-Content-Type-Options"))
	assert.Equal(t, "DENY", headers.Get("X-Frame-Options"))
	assert.Equal(t, "1; mode=block", headers.Get("X-XSS-Protection"))
	assert.Contains(t, headers.Get("Strict-Transport-Security"), "max-age=31536000")
	assert.Contains(t, headers.Get("Content-Security-Policy"), "default-src 'self'")
	assert.Contains(t, headers.Get("Referrer-Policy"), "strict-origin")
	assert.NotEmpty(t, headers.Get("Permissions-Policy"))
}

// TestAuthMiddleware_InvalidAuthorizationFormat verifies invalid authorization format is rejected
func TestAuthMiddleware_InvalidAuthorizationFormat(t *testing.T) {
	tests := []struct {
		name   string
		header string
	}{
		{"No Bearer prefix", "just-a-token"},
		{"Wrong prefix", "Basic dXNlcjpwYXNz"},
		{"Empty Bearer", "Bearer "},
		{"Multiple spaces", "Bearer  token  extra"},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			stub := &stubAuthProvider{
				validateFn: func(ctx context.Context, token string) (*auth.User, error) {
					// Should not be called for invalid format, but if it is, return error
					return nil, errors.New("should not be called")
				},
			}

			e := setupProtectedRoute(t, stub)
			req := httptest.NewRequest(http.MethodGet, "/api/v1/protected", nil)
			req.Header.Set("Authorization", tt.header)
			rec := httptest.NewRecorder()

			e.ServeHTTP(rec, req)

			assert.Equal(t, http.StatusUnauthorized, rec.Code)
		})
	}
}

// TestAuthMiddleware_ContextPropagation verifies that context is properly propagated
func TestAuthMiddleware_ContextPropagation(t *testing.T) {
	expectedUser := &auth.User{
		ID:        "context-user",
		Email:     "context@example.com",
		Name:      "Context User",
		Role:      "admin",
		ProjectID: "project-ctx",
	}

	contextReceived := false
	stub := &stubAuthProvider{
		validateFn: func(ctx context.Context, token string) (*auth.User, error) {
			// Verify context is passed
			assert.NotNil(t, ctx)
			contextReceived = true
			return expectedUser, nil
		},
	}

	e := setupProtectedRoute(t, stub)
	req := httptest.NewRequest(http.MethodGet, "/api/v1/protected", nil)
	req.Header.Set("Authorization", "Bearer context-token")
	rec := httptest.NewRecorder()

	e.ServeHTTP(rec, req)

	assert.Equal(t, http.StatusOK, rec.Code)
	assert.True(t, contextReceived, "context should have been passed to validateFn")
}

// TestAuthMiddleware_SkipperFunction verifies that skipper function works correctly
func TestAuthMiddleware_SkipperFunction(t *testing.T) {
	stub := &stubAuthProvider{
		validateFn: func(ctx context.Context, token string) (*auth.User, error) {
			t.Fatal("validateFn should not be called when skipped")
			return nil, errors.New("should not be called")
		},
	}

	e := echo.New()
	api := e.Group("/api/v1")

	// Add middleware with custom skipper
	api.Use(AuthAdapterMiddleware(AuthAdapterConfig{
		AuthProvider: stub,
		Skipper: func(c echo.Context) bool {
			// Skip authentication for /public paths
			return c.Path() == "/api/v1/public"
		},
	}))

	api.GET("/public", func(c echo.Context) error {
		return c.JSON(http.StatusOK, map[string]string{"status": "public"})
	})
	api.GET("/private", func(c echo.Context) error {
		return c.JSON(http.StatusOK, map[string]string{"status": "private"})
	})

	// Test public endpoint - should not require auth
	req := httptest.NewRequest(http.MethodGet, "/api/v1/public", nil)
	rec := httptest.NewRecorder()
	e.ServeHTTP(rec, req)
	assert.Equal(t, http.StatusOK, rec.Code)

	// Test private endpoint - should require auth
	req = httptest.NewRequest(http.MethodGet, "/api/v1/private", nil)
	rec = httptest.NewRecorder()
	e.ServeHTTP(rec, req)
	assert.Equal(t, http.StatusUnauthorized, rec.Code)
}

// TestAuthMiddleware_RedisRateLimiting verifies Redis-based rate limiting
func TestAuthMiddleware_RedisRateLimiting(t *testing.T) {
	stub := &stubAuthProvider{
		validateFn: func(ctx context.Context, token string) (*auth.User, error) {
			return &auth.User{ID: "redis-user", Email: "redis@example.com"}, nil
		},
	}

	// Note: This is a simplified test. In a real scenario, we'd use a mock Redis client
	// For now, we test the in-memory fallback when Redis is nil
	e := echo.New()
	api := e.Group("/api/v1")

	rateLimiter := NewRateLimitMiddleware(RateLimitMiddlewareConfig{
		RedisClient:       nil, // Will use in-memory limiter
		RequestsPerSecond: 10,
		BurstSize:         5,
	})

	api.Use(AuthAdapterMiddleware(AuthAdapterConfig{
		AuthProvider: stub,
	}))

	api.GET("/redis-rate-test", func(c echo.Context) error {
		return c.JSON(http.StatusOK, map[string]string{"status": "ok"})
	})

	req := httptest.NewRequest(http.MethodGet, "/api/v1/redis-rate-test", nil)
	req.Header.Set("Authorization", "Bearer valid-token")
	rec := httptest.NewRecorder()

	e.ServeHTTP(rec, req)

	assert.Equal(t, http.StatusOK, rec.Code)
}

// TestJWTMiddleware_ValidToken verifies JWT middleware with valid token
func TestJWTMiddleware_ValidToken(t *testing.T) {
	secretKey := []byte("test-secret-key")

	// Create a valid JWT token
	claims := &JWTClaims{
		UserID:    "jwt-user-123",
		ProjectID: "jwt-project-456",
		Role:      "admin",
		RegisteredClaims: jwt.RegisteredClaims{
			ExpiresAt: jwt.NewNumericDate(time.Now().Add(1 * time.Hour)),
			IssuedAt:  jwt.NewNumericDate(time.Now()),
		},
	}

	token := jwt.NewWithClaims(jwt.SigningMethodHS256, claims)
	tokenString, err := token.SignedString(secretKey)
	require.NoError(t, err)

	e := echo.New()
	api := e.Group("/api/v1")
	api.Use(JWTMiddleware(JWTConfig{
		SecretKey: secretKey,
	}))
	api.GET("/jwt-test", func(c echo.Context) error {
		userID := c.Get("user_id")
		projectID := c.Get("project_id")
		role := c.Get("role")

		return c.JSON(http.StatusOK, map[string]interface{}{
			"user_id":    userID,
			"project_id": projectID,
			"role":       role,
		})
	})

	req := httptest.NewRequest(http.MethodGet, "/api/v1/jwt-test", nil)
	req.Header.Set("Authorization", fmt.Sprintf("Bearer %s", tokenString))
	rec := httptest.NewRecorder()

	e.ServeHTTP(rec, req)

	assert.Equal(t, http.StatusOK, rec.Code)

	var response map[string]interface{}
	require.NoError(t, json.NewDecoder(rec.Body).Decode(&response))

	assert.Equal(t, "jwt-user-123", response["user_id"])
	assert.Equal(t, "jwt-project-456", response["project_id"])
	assert.Equal(t, "admin", response["role"])
}

// TestJWTMiddleware_InvalidSignature verifies JWT middleware rejects invalid signatures
func TestJWTMiddleware_InvalidSignature(t *testing.T) {
	secretKey := []byte("test-secret-key")
	wrongSecretKey := []byte("wrong-secret-key")

	// Create a token with wrong secret
	claims := &JWTClaims{
		UserID:    "jwt-user-123",
		ProjectID: "jwt-project-456",
		Role:      "admin",
		RegisteredClaims: jwt.RegisteredClaims{
			ExpiresAt: jwt.NewNumericDate(time.Now().Add(1 * time.Hour)),
		},
	}

	token := jwt.NewWithClaims(jwt.SigningMethodHS256, claims)
	tokenString, err := token.SignedString(wrongSecretKey)
	require.NoError(t, err)

	e := echo.New()
	api := e.Group("/api/v1")
	api.Use(JWTMiddleware(JWTConfig{
		SecretKey: secretKey, // Different secret
	})
	api.GET("/jwt-test", func(c echo.Context) error {
		return c.JSON(http.StatusOK, map[string]string{"status": "ok"})
	})

	req := httptest.NewRequest(http.MethodGet, "/api/v1/jwt-test", nil)
	req.Header.Set("Authorization", fmt.Sprintf("Bearer %s", tokenString))
	rec := httptest.NewRecorder()

	e.ServeHTTP(rec, req)

	assert.Equal(t, http.StatusUnauthorized, rec.Code)
}
