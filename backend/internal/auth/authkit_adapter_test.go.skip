		// Arrange
		// mockDB no longer needed
		// mockDB setup removed
		// mockDB cleanup removed

		adapter := NewAuthKitAdapter(TestClientID, TestJWTSecret, nil)
		ctx := context.Background()
		userID := "user_nonexistent"

		// Expect database update to affect 0 rows (user doesn't exist)
		mockDB.ExpectExec(`UPDATE public.profiles`).
			WithArgs(userID).
			WillReturnResult(pgxmock.NewResult("UPDATE", 0))

		// Act
		err = adapter.DeleteUser(ctx, userID)

		// Assert
		assert.NoError(t, err, "Should succeed even if user doesn't exist (idempotent)")

		err = mockDB.ExpectationsWereMet()
		assert.NoError(t, err)
	})
}

