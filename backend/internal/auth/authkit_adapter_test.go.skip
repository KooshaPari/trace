// TestCreateUser tests that CreateUser returns an error
func TestCreateUser(t *testing.T) {
	t.Run("returns error indicating WorkOS-only user creation", func(t *testing.T) {
		// Arrange
		// mockDB no longer needed
		// mockDB setup removed
		// mockDB cleanup removed

		adapter := NewAuthKitAdapter(TestClientID, TestJWTSecret, nil)
		ctx := context.Background()

		// Act
		user, err := adapter.CreateUser(ctx, "new@example.com", "password123", "New User")

		// Assert
		assert.Error(t, err, "Should return error for direct user creation")
		assert.Nil(t, user, "User should be nil")
		assert.Contains(t, err.Error(), "WorkOS/AuthKit", "Error should mention WorkOS/AuthKit")
		assert.Contains(t, err.Error(), "not directly", "Error should indicate direct creation not allowed")

		// No database calls should have been made
		err = mockDB.ExpectationsWereMet()
		assert.NoError(t, err)
	})
}

// TestUpdateUser_Success tests successful user update
func TestUpdateUser_Success(t *testing.T) {
	t.Run("updates user metadata successfully", func(t *testing.T) {
		// Arrange
		// mockDB no longer needed
		// mockDB setup removed
		// mockDB cleanup removed

		adapter := NewAuthKitAdapter(TestClientID, TestJWTSecret, nil)
		ctx := context.Background()
		userID := "user_01H8XYZ123"

		updates := map[string]interface{}{
			"department": "product",
			"title":      "Senior Developer",
		}

		mockProfile := DefaultMockProfile()
		updatedMetadata := map[string]interface{}{
			"department": "product",
			"title":      "Senior Developer",
			"role":       "developer",
		}
		mockMetadataJSON := MetadataToJSON(t, updatedMetadata)

		// Expect database update
		mockDB.ExpectQuery(`UPDATE public.profiles`).
			WithArgs(pgxmock.AnyArg(), userID).
			WillReturnRows(pgxmock.NewRows([]string{
				"id", "auth_id", "workos_user_id", "workos_org_id", "email", "full_name", "avatar_url", "metadata",
			}).AddRow(
				mockProfile.ID,
				mockProfile.AuthID,
				mockProfile.WorkosUserID,
				mockProfile.WorkosOrgID,
				mockProfile.Email,
				mockProfile.FullName,
				mockProfile.AvatarURL,
				mockMetadataJSON,
			))

		// Act
		user, err := adapter.UpdateUser(ctx, userID, updates)

		// Assert
		require.NoError(t, err, "Should update user successfully")
		assert.NotNil(t, user, "User should not be nil")
		assert.Equal(t, mockProfile.WorkosUserID, user.ID)
		assert.NotNil(t, user.Metadata)

		err = mockDB.ExpectationsWereMet()
		assert.NoError(t, err)
	})
}

