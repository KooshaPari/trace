// TestNewAuthKitAdapter tests the constructor
func TestNewAuthKitAdapter(t *testing.T) {
	t.Run("creates adapter with valid parameters", func(t *testing.T) {
		// Arrange
		jwtSecret := TestJWTSecret
		clientID := TestClientID

		// Act
		adapter := NewAuthKitAdapter(clientID, jwtSecret, nil)

		// Assert
		assert.NotNil(t, adapter, "Adapter should not be nil")
		assert.NotNil(t, adapter.tokenBridge, "TokenBridge should be initialized")
		assert.NotNil(t, adapter.db, "Database pool should be set")
		assert.NotNil(t, adapter.httpClient, "HTTP client should be initialized")
		assert.Equal(t, 10*time.Second, adapter.httpClient.Timeout, "HTTP client timeout should be 10 seconds")
	})

	t.Run("initializes with empty secret", func(t *testing.T) {
		// Arrange
		// mockDB no longer needed
		// mockDB setup removed
		// mockDB cleanup removed

		// Act
		adapter := NewAuthKitAdapter(TestClientID, "", nil)

		// Assert
		assert.NotNil(t, adapter, "Adapter should be created even with empty secret")
		assert.NotNil(t, adapter.tokenBridge, "TokenBridge should be initialized")
	})
}

// TestValidateToken_Success tests successful token validation
func TestValidateToken_Success(t *testing.T) {
	t.Run("validates correct WorkOS token and syncs profile", func(t *testing.T) {
		// Arrange
		// mockDB no longer needed
		// mockDB setup removed
		// mockDB cleanup removed

		adapter := NewAuthKitAdapter(TestClientID, TestJWTSecret, nil)
		ctx := context.Background()
		token := CreateValidWorkOSToken(t)

		mockProfile := DefaultMockProfile()

		// Expect database call for profile sync
		mockDB.ExpectQuery(`SELECT id, workos_user_id, workos_org_id, email, full_name`).
			WithArgs(
				"test@example.com",
				"Test User",
				"user_01H8XYZ123",
				"org_01H8ABC456",
				pgxmock.AnyArg(),
			).
			WillReturnRows(pgxmock.NewRows([]string{
				"id", "workos_user_id", "workos_org_id", "email", "full_name",
			}).AddRow(
				mockProfile.ID,
				mockProfile.WorkosUserID,
				mockProfile.WorkosOrgID,
				mockProfile.Email,
				mockProfile.FullName,
			))

		// Act
		user, err := adapter.ValidateToken(ctx, token)

		// Assert
		require.NoError(t, err, "Should validate token successfully")
		assert.NotNil(t, user, "User should not be nil")
		assert.Equal(t, "user_01H8XYZ123", user.ID)
		assert.Equal(t, "test@example.com", user.Email)
		assert.Equal(t, "Test User", user.Name)
		assert.Equal(t, "admin", user.Role)
		assert.Equal(t, "org_01H8ABC456", user.ProjectID)
		assert.NotNil(t, user.Metadata)
		assert.Equal(t, mockProfile.ID, user.Metadata["profile_id"])

		// Verify all expectations were met
		err = mockDB.ExpectationsWereMet()
		assert.NoError(t, err, "All database expectations should be met")
	})
}

// TestValidateToken_InvalidTokens tests various invalid token scenarios
func TestValidateToken_InvalidTokens(t *testing.T) {
	testCases := []struct {
		name          string
		tokenFunc     func(t *testing.T) string
		expectedError string
	}{
		{
			name:          "expired token",
			tokenFunc:     CreateExpiredWorkOSToken,
			expectedError: "failed to parse token",
		},
		{
			name:          "invalid signature",
			tokenFunc:     CreateTokenWithInvalidSignature,
			expectedError: "failed to parse token",
		},
		{
			name:          "wrong signing method",
			tokenFunc:     CreateTokenWithWrongSigningMethod,
			expectedError: "failed to parse token",
		},
		{
			name:          "malformed token",
			tokenFunc:     CreateMalformedToken,
			expectedError: "failed to parse token",
		},
	}

	for _, tc := range testCases {
		t.Run(tc.name, func(t *testing.T) {
			// Arrange
			// mockDB no longer needed
			// mockDB setup removed
			// mockDB cleanup removed

			adapter := NewAuthKitAdapter(TestClientID, TestJWTSecret, nil)
			ctx := context.Background()
			token := tc.tokenFunc(t)

			// Act
			user, err := adapter.ValidateToken(ctx, token)

			// Assert
			assert.Error(t, err, "Should return error for invalid token")
			assert.Nil(t, user, "User should be nil on error")
			assert.Contains(t, err.Error(), tc.expectedError, "Error message should contain expected text")

			// No database calls should have been made
			err = mockDB.ExpectationsWereMet()
			assert.NoError(t, err, "No database expectations for invalid tokens")
		})
	}
}

