		offset := 0

		// Expect database query to fail
		mockDB.ExpectQuery(`SELECT id, auth_id, workos_user_id, workos_org_id, email, full_name, avatar_url, metadata`).
			WithArgs(limit, offset).
			WillReturnError(errors.New("database connection lost"))

		// Act
		users, err := adapter.ListUsers(ctx, limit, offset)

		// Assert
		assert.Error(t, err, "Should return error on database failure")
		assert.Nil(t, users, "Users should be nil on error")
		assert.Contains(t, err.Error(), "failed to list users", "Error should indicate list failure")

		err = mockDB.ExpectationsWereMet()
		assert.NoError(t, err)
	})
}

