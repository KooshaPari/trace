// TestGetUser_Success tests successful user retrieval
func TestGetUser_Success(t *testing.T) {
	t.Run("retrieves existing user by WorkOS user ID", func(t *testing.T) {
		// Arrange
		// mockDB no longer needed
		// mockDB setup removed
		// mockDB cleanup removed

		adapter := NewAuthKitAdapter(TestClientID, TestJWTSecret, nil)
		ctx := context.Background()
		userID := "user_01H8XYZ123"

		mockProfile := DefaultMockProfile()
		mockMetadata := MetadataToJSON(t, mockProfile.Metadata)

		// Expect database query
		mockDB.ExpectQuery(`SELECT id, auth_id, workos_user_id, workos_org_id, email, full_name, avatar_url, metadata`).
			WithArgs(userID).
			WillReturnRows(pgxmock.NewRows([]string{
				"id", "auth_id", "workos_user_id", "workos_org_id", "email", "full_name", "avatar_url", "metadata",
			}).AddRow(
				mockProfile.ID,
				mockProfile.AuthID,
				mockProfile.WorkosUserID,
				mockProfile.WorkosOrgID,
				mockProfile.Email,
				mockProfile.FullName,
				mockProfile.AvatarURL,
				mockMetadata,
			))

		// Act
		user, err := adapter.GetUser(ctx, userID)

		// Assert
		require.NoError(t, err, "Should retrieve user successfully")
		assert.NotNil(t, user, "User should not be nil")
		assert.Equal(t, mockProfile.WorkosUserID, user.ID)
		assert.Equal(t, mockProfile.Email, user.Email)
		assert.Equal(t, mockProfile.FullName, user.Name)
		assert.Equal(t, mockProfile.WorkosOrgID, user.ProjectID)
		assert.NotNil(t, user.Metadata)

		// Verify all expectations were met
		err = mockDB.ExpectationsWereMet()
		assert.NoError(t, err)
	})
}

