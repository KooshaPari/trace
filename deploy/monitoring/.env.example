# ============================================================================
# Prometheus & Alertmanager Configuration
# ============================================================================

# Slack Integration
# 1. Create Slack App: https://api.slack.com/apps
# 2. Add Incoming Webhook
# 3. Copy webhook URL below
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Email/SMTP Configuration for critical alerts
SMTP_USERNAME=alerts@example.com
SMTP_PASSWORD=your-smtp-password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# PagerDuty Integration (optional, for on-call)
# 1. Create service in PagerDuty
# 2. Add Events integration
# 3. Copy integration key
PAGERDUTY_SERVICE_KEY=your-pagerduty-service-key

# ============================================================================
# Database Configuration (for PostgreSQL Exporter)
# ============================================================================
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tracertm

# ============================================================================
# Redis Configuration (for Redis Exporter)
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379

# ============================================================================
# Prometheus Configuration
# ============================================================================
# Retention period for metrics
PROMETHEUS_RETENTION=15d

# Scrape interval (in seconds)
PROMETHEUS_SCRAPE_INTERVAL=15

# Evaluation interval for alert rules (in seconds)
PROMETHEUS_EVALUATION_INTERVAL=15

# ============================================================================
# Alertmanager Configuration
# ============================================================================
# Alert grouping settings
ALERTMANAGER_GROUP_WAIT=10s
ALERTMANAGER_GROUP_INTERVAL=10s
ALERTMANAGER_REPEAT_INTERVAL=12h

# ============================================================================
# External Labels
# ============================================================================
# These labels are added to all metrics scraped by Prometheus
CLUSTER_NAME=tracertm
ENVIRONMENT=production
MONITORING_INSTANCE=prometheus-1
