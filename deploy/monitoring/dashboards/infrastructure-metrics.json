      }
    },
    {
      "id": 11,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 32
      },
      "type": "graph",
      "title": "File Descriptors",
      "targets": [
        {
          "expr": "process_open_fds{job=\"go-backend\"}",
          "legendFormat": "Go Backend",
          "refId": "A"
        },
        {
          "expr": "process_open_fds{job=\"python-backend\"}",
          "legendFormat": "Python Backend",
          "refId": "B"
        },
        {
          "expr": "process_max_fds{job=\"go-backend\"}",
          "legendFormat": "Max FDs",
