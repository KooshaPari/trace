{
  "id": null,
  "uid": "infrastructure-metrics",
  "title": "TraceRTM Infrastructure Metrics",
  "tags": [
    "infrastructure",
    "system",
    "resources"
  ],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 0,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "type": "graph",
      "title": "CPU Usage",
      "targets": [
        {
          "expr": "100 - (avg by (instance) (irate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "System CPU",
          "refId": "A"
        },
        {
          "expr": "rate(process_cpu_seconds_total{job=\"go-backend\"}[5m]) * 100",
          "legendFormat": "Go Backend",
          "refId": "B"
        },
        {
          "expr": "rate(process_cpu_seconds_total{job=\"python-backend\"}[5m]) * 100",
          "legendFormat": "Python Backend",
          "refId": "C"
        }
      ],
      "yaxes": [
        {
          "format": "percent",
          "label": "CPU %",
          "max": 100
        },
        {
          "format": "short"
        }
      ],
      "xaxis": {
        "mode": "time"
      },
      "legend": {
        "show": true,
        "values": true,
        "current": true
      },
      "tooltip": {
        "shared": true,
        "sort": 2
      },
      "alert": {
        "name": "High CPU Usage",
        "conditions": [
          {
            "evaluator": {
              "params": [
                80
              ],
              "type": "gt"
            },
            "operator": {
              "type": "and"
            },
            "query": {
              "params": [
                "A",
                "5m",
                "now"
              ]
            },
            "reducer": {
              "params": [],
              "type": "avg"
            },
            "type": "query"
          }
        ],
        "executionErrorState": "alerting",
        "frequency": "1m",
        "handler": 1,
        "noDataState": "no_data",
        "notifications": []
      }
    },
    {
      "id": 2,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "type": "graph",
      "title": "Memory Usage",
      "targets": [
        {
          "expr": "(node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes) / node_memory_MemTotal_bytes * 100",
          "legendFormat": "System Memory %",
          "refId": "A"
        },
        {
          "expr": "process_resident_memory_bytes{job=\"go-backend\"} / 1024 / 1024",
          "legendFormat": "Go Backend (MB)",
          "refId": "B"
        },
        {
          "expr": "process_resident_memory_bytes{job=\"python-backend\"} / 1024 / 1024",
          "legendFormat": "Python Backend (MB)",
          "refId": "C"
        },
        {
          "expr": "go_memstats_heap_alloc_bytes{job=\"go-backend\"} / 1024 / 1024",
          "legendFormat": "Go Heap (MB)",
          "refId": "D"
        }
      ],
      "yaxes": [
        {
          "format": "short",
          "label": "Memory"
        },
        {
          "format": "short"
        }
      ],
      "xaxis": {
        "mode": "time"
      },
      "legend": {
        "show": true,
        "values": true,
        "current": true
      },
      "tooltip": {
        "shared": true,
        "sort": 2
      }
    },
    {
      "id": 3,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "type": "graph",
      "title": "Disk I/O",
      "targets": [
        {
          "expr": "rate(node_disk_read_bytes_total[5m])",
          "legendFormat": "Read {{device}}",
          "refId": "A"
        },
        {
          "expr": "rate(node_disk_written_bytes_total[5m])",
          "legendFormat": "Write {{device}}",
          "refId": "B"
        }
      ],
      "yaxes": [
        {
          "format": "Bps",
          "label": "Bytes/sec"
        },
        {
          "format": "short"
        }
      ],
      "xaxis": {
        "mode": "time"
      },
      "legend": {
        "show": true,
        "values": true,
        "current": true
      },
      "tooltip": {
        "shared": true,
        "sort": 2
      }
    },
    {
      "id": 4,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "type": "graph",
      "title": "Network Traffic",
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{device!=\"lo\"}[5m])",
          "legendFormat": "Receive {{device}}",
          "refId": "A"
        },
        {
          "expr": "rate(node_network_transmit_bytes_total{device!=\"lo\"}[5m])",
          "legendFormat": "Transmit {{device}}",
          "refId": "B"
        }
      ],
      "yaxes": [
        {
          "format": "Bps",
          "label": "Bytes/sec"
        },
        {
          "format": "short"
        }
      ],
      "xaxis": {
        "mode": "time"
      },
      "legend": {
        "show": true,
        "values": true,
        "current": true
      },
      "tooltip": {
        "shared": true,
        "sort": 2
      }
    },
    {
      "id": 5,
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 16
      },
      "type": "graph",
      "title": "PostgreSQL Connections",
      "targets": [
        {
          "expr": "pg_stat_database_numbackends{datname=\"tracertm\"}",
          "legendFormat": "Active Connections",
          "refId": "A"
        },
        {
          "expr": "pg_settings_max_connections",
          "legendFormat": "Max Connections",
          "refId": "B"
        }
      ],
      "yaxes": [
        {
          "format": "short",
          "label": "Connections"
        },
        {
          "format": "short"
        }
      ],
      "xaxis": {
        "mode": "time"
      },
      "legend": {
        "show": true,
        "values": true,
        "current": true
      },
      "tooltip": {
        "shared": true,
        "sort": 2
      }
    },
    {
      "id": 6,
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 16
      },
      "type": "graph",
      "title": "PostgreSQL Transaction Rate",
      "targets": [
        {
          "expr": "rate(pg_stat_database_xact_commit{datname=\"tracertm\"}[5m])",
          "legendFormat": "Commits/sec",
          "refId": "A"
        },
        {
          "expr": "rate(pg_stat_database_xact_rollback{datname=\"tracertm\"}[5m])",
          "legendFormat": "Rollbacks/sec",
          "refId": "B"
        }
      ],
      "yaxes": [
        {
          "format": "short",
          "label": "Transactions/sec"
        },
        {
          "format": "short"
        }
      ],
      "xaxis": {
        "mode": "time"
      },
      "legend": {
        "show": true,
        "values": true,
        "current": true
      },
      "tooltip": {
        "shared": true,
        "sort": 2
      }
    },
    {
      "id": 7,
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 16
      },
      "type": "graph",
      "title": "PostgreSQL Cache Hit Rate",
      "targets": [
        {
          "expr": "sum(pg_stat_database_blks_hit{datname=\"tracertm\"}) / (sum(pg_stat_database_blks_hit{datname=\"tracertm\"}) + sum(pg_stat_database_blks_read{datname=\"tracertm\"})) * 100",
          "legendFormat": "Cache Hit Rate %",
          "refId": "A"
        }
      ],
      "yaxes": [
        {
          "format": "percent",
          "label": "Hit Rate %",
          "min": 0,
          "max": 100
        },
        {
          "format": "short"
        }
      ],
      "xaxis": {
        "mode": "time"
      },
      "legend": {
        "show": true,
        "values": true,
        "current": true
      },
      "tooltip": {
        "shared": true,
        "sort": 2
      }
    },
    {
      "id": 8,
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 24
      },
      "type": "graph",
      "title": "Redis Memory Usage",
      "targets": [
        {
          "expr": "redis_memory_used_bytes / 1024 / 1024",
          "legendFormat": "Used Memory (MB)",
          "refId": "A"
        },
        {
          "expr": "redis_memory_max_bytes / 1024 / 1024",
          "legendFormat": "Max Memory (MB)",
          "refId": "B"
        }
      ],
      "yaxes": [
        {
          "format": "short",
          "label": "Memory (MB)"
        },
        {
          "format": "short"
        }
      ],
      "xaxis": {
        "mode": "time"
      },
      "legend": {
        "show": true,
        "values": true,
        "current": true
      },
      "tooltip": {
        "shared": true,
        "sort": 2
      }
    },
    {
      "id": 9,
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 24
      },
      "type": "graph",
      "title": "Redis Operations",
      "targets": [
        {
          "expr": "rate(redis_commands_processed_total[5m])",
          "legendFormat": "Commands/sec",
          "refId": "A"
        },
        {
          "expr": "rate(redis_keyspace_hits_total[5m])",
          "legendFormat": "Hits/sec",
          "refId": "B"
        },
        {
          "expr": "rate(redis_keyspace_misses_total[5m])",
          "legendFormat": "Misses/sec",
          "refId": "C"
        }
      ],
      "yaxes": [
        {
          "format": "short",
          "label": "Operations/sec"
