    },
    {
      "id": 12,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 32
      },
      "type": "graph",
      "title": "Garbage Collection (Go)",
      "targets": [
        {
          "expr": "rate(go_gc_duration_seconds_sum{job=\"go-backend\"}[5m])",
          "legendFormat": "GC Duration",
