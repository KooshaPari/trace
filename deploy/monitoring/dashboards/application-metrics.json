{
  "id": null,
  "uid": "application-metrics",
  "title": "TraceRTM Application Metrics",
  "tags": [
    "application",
    "api",
    "performance"
  ],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 0,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "type": "graph",
      "title": "API Request Rate",
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"go-backend\"}[5m])) by (method, endpoint)",
          "legendFormat": "{{method}} {{endpoint}}",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_requests_total{job=\"python-backend\"}[5m])) by (method, path)",
          "legendFormat": "Python: {{method}} {{path}}",
          "refId": "B"
        }
      ],
      "yaxes": [
        {
          "format": "reqps",
          "label": "Requests/sec"
        },
        {
          "format": "short"
        }
      ],
      "xaxis": {
        "mode": "time"
      },
      "legend": {
        "show": true,
        "values": true,
        "current": true
      },
      "tooltip": {
        "shared": true,
        "sort": 2
      }
    },
    {
      "id": 2,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "type": "graph",
      "title": "API Latency (p50, p95, p99)",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=\"go-backend\"}[5m])) by (le, endpoint))",
          "legendFormat": "p50 - {{endpoint}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"go-backend\"}[5m])) by (le, endpoint))",
          "legendFormat": "p95 - {{endpoint}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"go-backend\"}[5m])) by (le, endpoint))",
          "legendFormat": "p99 - {{endpoint}}",
          "refId": "C"
        }
      ],
      "yaxes": [
        {
          "format": "s",
          "label": "Latency"
        },
        {
          "format": "short"
        }
      ],
      "xaxis": {
        "mode": "time"
      },
      "legend": {
        "show": true,
        "values": true,
        "current": true
      },
      "tooltip": {
        "shared": true,
        "sort": 2
      }
    },
    {
      "id": 3,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "type": "graph",
      "title": "Error Rate by Endpoint",
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"go-backend\",status_code=~\"5..\"}[5m])) by (endpoint)",
          "legendFormat": "5xx - {{endpoint}}",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_requests_total{job=\"go-backend\",status_code=~\"4..\"}[5m])) by (endpoint)",
          "legendFormat": "4xx - {{endpoint}}",
          "refId": "B"
        }
      ],
      "yaxes": [
        {
          "format": "reqps",
          "label": "Errors/sec"
        },
        {
          "format": "short"
        }
      ],
      "xaxis": {
        "mode": "time"
      },
      "legend": {
        "show": true,
        "values": true,
        "current": true
      },
      "tooltip": {
        "shared": true,
        "sort": 2
      },
      "alert": {
        "name": "High Error Rate",
        "conditions": [
          {
            "evaluator": {
              "params": [
                10
              ],
              "type": "gt"
            },
            "operator": {
              "type": "and"
            },
            "query": {
              "params": [
                "A",
                "5m",
                "now"
              ]
            },
            "reducer": {
              "params": [],
              "type": "avg"
            },
            "type": "query"
          }
        ],
        "executionErrorState": "alerting",
        "frequency": "1m",
        "handler": 1,
        "noDataState": "no_data",
        "notifications": []
      }
    },
    {
      "id": 4,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "type": "stat",
      "title": "Success Rate (Last 5m)",
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"go-backend\",status_code!~\"5..\"}[5m])) / sum(rate(http_requests_total{job=\"go-backend\"}[5m])) * 100",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 95
              },
              {
                "color": "green",
                "value": 99
              }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 16
      },
      "type": "graph",
      "title": "Database Query Duration",
      "targets": [
        {
          "expr": "rate(db_query_duration_seconds_sum{job=\"go-backend\"}[5m]) / rate(db_query_duration_seconds_count{job=\"go-backend\"}[5m])",
          "legendFormat": "{{operation}}",
          "refId": "A"
        }
      ],
      "yaxes": [
        {
          "format": "s",
          "label": "Duration"
        },
        {
          "format": "short"
        }
      ],
      "xaxis": {
        "mode": "time"
      },
      "legend": {
        "show": true,
        "values": true,
        "current": true
      },
      "tooltip": {
        "shared": true,
        "sort": 2
      }
    },
    {
      "id": 6,
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 16
      },
      "type": "graph",
      "title": "Cache Hit Rate",
      "targets": [
        {
          "expr": "sum(rate(cache_hits_total{job=\"go-backend\"}[5m])) / (sum(rate(cache_hits_total{job=\"go-backend\"}[5m])) + sum(rate(cache_misses_total{job=\"go-backend\"}[5m]))) * 100",
          "legendFormat": "Hit Rate %",
          "refId": "A"
        }
      ],
      "yaxes": [
        {
          "format": "percent",
          "label": "Hit Rate",
          "min": 0,
          "max": 100
        },
        {
          "format": "short"
        }
      ],
      "xaxis": {
        "mode": "time"
      },
      "legend": {
        "show": true,
        "values": true,
        "current": true
      },
      "tooltip": {
        "shared": true,
        "sort": 2
      }
    },
    {
      "id": 7,
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 16
      },
      "type": "graph",
      "title": "Active Goroutines / Threads",
      "targets": [
        {
          "expr": "go_goroutines{job=\"go-backend\"}",
          "legendFormat": "Go Backend",
          "refId": "A"
        },
        {
          "expr": "process_threads{job=\"python-backend\"}",
          "legendFormat": "Python Backend",
          "refId": "B"
        }
      ],
      "yaxes": [
        {
          "format": "short",
          "label": "Count"
        },
        {
          "format": "short"
        }
      ],
      "xaxis": {
        "mode": "time"
      },
      "legend": {
        "show": true,
        "values": true,
        "current": true
      },
      "tooltip": {
        "shared": true,
        "sort": 2
      }
    },
    {
      "id": 8,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "type": "graph",
      "title": "WebSocket Connections",
      "targets": [
        {
          "expr": "websocket_connections_active{job=\"go-backend\"}",
          "legendFormat": "Active Connections",
          "refId": "A"
        },
        {
          "expr": "rate(websocket_messages_sent_total{job=\"go-backend\"}[5m])",
          "legendFormat": "Messages Sent/sec",
          "refId": "B"
        },
        {
          "expr": "rate(websocket_messages_received_total{job=\"go-backend\"}[5m])",
          "legendFormat": "Messages Received/sec",
          "refId": "C"
        }
      ],
      "yaxes": [
        {
          "format": "short",
          "label": "Count"
        },
        {
          "format": "short"
        }
      ],
      "xaxis": {
        "mode": "time"
      },
      "legend": {
        "show": true,
        "values": true,
        "current": true
      },
      "tooltip": {
        "shared": true,
        "sort": 2
      }
    },
    {
      "id": 9,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 24
      },
      "type": "graph",
      "title": "Temporal Workflow Metrics",
      "targets": [
        {
          "expr": "rate(temporal_workflow_started_total[5m])",
          "legendFormat": "Workflows Started/sec",
          "refId": "A"
        },
        {
          "expr": "rate(temporal_workflow_completed_total[5m])",
          "legendFormat": "Workflows Completed/sec",
          "refId": "B"
        },
        {
          "expr": "rate(temporal_workflow_failed_total[5m])",
          "legendFormat": "Workflows Failed/sec",
          "refId": "C"
        },
        {
          "expr": "temporal_workflow_active",
          "legendFormat": "Active Workflows",
          "refId": "D"
        }
      ],
      "yaxes": [
        {
          "format": "short",
          "label": "Count"
        },
        {
          "format": "short"
        }
      ],
      "xaxis": {
        "mode": "time"
      },
      "legend": {
        "show": true,
        "values": true,
        "current": true
      },
      "tooltip": {
        "shared": true,
        "sort": 2
      }
    },
    {
      "id": 10,
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 32
      },
      "type": "table",
      "title": "Top 10 Slowest Endpoints",
      "targets": [
        {
          "expr": "topk(10, avg by (endpoint) (rate(http_request_duration_seconds_sum{job=\"go-backend\"}[5m]) / rate(http_request_duration_seconds_count{job=\"go-backend\"}[5m])))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "indexByName": {},
            "renameByName": {
              "endpoint": "Endpoint",
              "Value": "Avg Duration (s)"
            }
          }
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "interval",
        "type": "interval",
        "query": "1m,5m,10m,30m,1h",
        "current": {
          "text": "5m",
          "value": "5m"
        }
      }
    ]
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": [
      "5s",
      "10s",
      "30s",
      "1m",
      "5m",
      "15m",
      "30m",
      "1h"
    ]
  }
}