        "w": 24,
        "x": 0,
        "y": 40
      },
      "type": "table",
      "title": "Top 10 Most Active Projects",
      "targets": [
        {
          "expr": "topk(10, sum by (project_id, project_name) (increase(project_activity_total[24h])))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "indexByName": {},
            "renameByName": {
              "project_name": "Project",
              "Value": "Activity Count (24h)"
            }
          }
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "project",
        "type": "query",
        "query": "label_values(project_activity_total, project_name)",
        "datasource": "Prometheus",
        "refresh": 1,
        "multi": true,
        "includeAll": true
      }
    ]
  },
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": [
      "30s",
      "1m",
      "5m",
      "15m",
      "30m",
      "1h"
    ]
  }
