{
  "id": null,
  "uid": "business-metrics",
  "title": "TraceRTM Business Metrics",
  "tags": [
    "business",
    "users",
    "features"
  ],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 0,
  "refresh": "1m",
  "panels": [
    {
      "id": 1,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "type": "stat",
      "title": "Active Users (Last 24h)",
      "targets": [
        {
          "expr": "count(count by (user_id) (increase(http_requests_total{job=\"go-backend\"}[24h])))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 10
              },
              {
                "color": "green",
                "value": 50
              }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "type": "stat",
      "title": "Total API Requests (Last 24h)",
      "targets": [
        {
          "expr": "sum(increase(http_requests_total{job=\"go-backend\"}[24h]))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0
        }
      }
    },
    {
      "id": 3,
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 8
      },
      "type": "piechart",
      "title": "Feature Usage Distribution",
      "targets": [
        {
          "expr": "sum by (feature) (increase(feature_usage_total[24h]))",
          "legendFormat": "{{feature}}",
          "refId": "A"
        }
      ],
      "options": {
        "pieType": "pie",
        "displayLabels": [
          "name",
          "percent"
        ],
        "legend": {
          "show": true,
          "placement": "right"
        }
