{
  "annotations": {
    "list": [{"builtIn": 1, "datasource": "-- Grafana --", "enable": true, "hide": true, "iconColor": "rgba(0, 211, 255, 1)", "name": "Annotations & Alerts", "type": "dashboard"}]
  },
  "editable": true,
  "gnetId": null,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {"asDropdown": false, "icon": "external link", "includeVars": true, "keepTime": true, "targetBlank": true, "title": "Backend Performance", "type": "link", "url": "/d/backend-performance"},
    {"asDropdown": false, "icon": "external link", "includeVars": true, "keepTime": true, "targetBlank": true, "title": "Frontend Performance", "type": "link", "url": "/d/frontend-performance"}
  ],
  "panels": [
    {
      "datasource": "Prometheus",
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "custom": {"axisPlacement": "auto", "drawStyle": "line", "fillOpacity": 20, "lineWidth": 2, "showPoints": "never"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 70}, {"color": "red", "value": 90}]}, "unit": "percent"}},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "id": 1,
      "options": {"legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "right"}},
      "targets": [
        {"expr": "100 - (avg by (job) (irate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)", "legendFormat": "{{ job }} CPU", "refId": "A"}
      ],
      "title": "CPU Usage by Service",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "custom": {"axisPlacement": "auto", "drawStyle": "line", "fillOpacity": 20, "lineWidth": 2}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 70}, {"color": "red", "value": 85}]}, "unit": "percent"}},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "id": 2,
      "options": {"legend": {"calcs": ["mean", "max"], "displayMode": "table", "placement": "right"}},
      "targets": [
        {"expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100", "legendFormat": "Memory Usage", "refId": "A"},
        {"expr": "deriv(node_memory_MemAvailable_bytes[10m]) < 0", "legendFormat": "Memory Leak Detected", "refId": "B"}
      ],
      "title": "Memory Usage with Leak Detection",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "percentage", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 70}, {"color": "red", "value": 85}]}, "unit": "percent"}},
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 8},
      "id": 3,
      "options": {"orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"]}, "showThresholdLabels": false, "showThresholdMarkers": true},
      "targets": [
        {"expr": "100 - ((node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"}) * 100)", "refId": "A"}
      ],
      "title": "Disk Usage",
      "type": "gauge"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "custom": {"axisPlacement": "auto", "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2}, "unit": "Bps"}},
      "gridPos": {"h": 6, "w": 6, "x": 6, "y": 8},
      "id": 4,
      "options": {"legend": {"calcs": ["mean"], "displayMode": "list", "placement": "bottom"}},
      "targets": [
        {"expr": "rate(node_disk_read_bytes_total[5m])", "legendFormat": "Read", "refId": "A"},
        {"expr": "rate(node_disk_written_bytes_total[5m])", "legendFormat": "Write", "refId": "B"}
      ],
      "title": "Disk I/O",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "custom": {"axisPlacement": "auto", "drawStyle": "line", "fillOpacity": 20, "lineWidth": 2}, "unit": "Bps"}},
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 8},
      "id": 5,
      "options": {"legend": {"calcs": ["mean"], "displayMode": "table", "placement": "right"}},
      "targets": [
        {"expr": "rate(node_network_receive_bytes_total[5m])", "legendFormat": "Inbound", "refId": "A"},
        {"expr": "rate(node_network_transmit_bytes_total[5m])", "legendFormat": "Outbound", "refId": "B"}
      ],
      "title": "Network Bandwidth",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "custom": {"align": "center", "displayMode": "color-background"}, "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": 0}, {"color": "green", "value": 1}]}, "mappings": [{"options": {"0": {"text": "DOWN"}, "1": {"text": "UP"}}, "type": "value"}]}},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 14},
      "id": 6,
      "options": {"showHeader": true},
      "targets": [
        {"expr": "up", "format": "table", "instant": true, "refId": "A"}
      ],
      "title": "Service Health Status",
      "transformations": [{"id": "organize", "options": {"excludeByName": {"Time": true}, "indexByName": {"job": 0, "instance": 1, "Value": 2}, "renameByName": {"job": "Service", "instance": "Instance", "Value": "Status"}}}],
      "type": "table"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "custom": {"align": "auto", "displayMode": "auto"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}}},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 14},
      "id": 7,
      "options": {"showHeader": true},
      "targets": [
        {"expr": "count by (job) (up == 1)", "format": "table", "instant": true, "refId": "A"}
      ],
      "title": "Process Status (Native Orchestration)",
      "transformations": [{"id": "organize", "options": {"excludeByName": {"Time": true}, "renameByName": {"job": "Process", "Value": "Instances"}}}],
      "type": "table"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 80}, {"color": "red", "value": 90}]}, "unit": "percent"}},
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 22},
      "id": 8,
      "options": {"orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [
        {"expr": "(pg_stat_database_numbackends{datname=\"tracertm\"} / pg_settings_max_connections) * 100", "refId": "A"}
      ],
      "title": "PostgreSQL Connection Pool Usage",
      "type": "gauge"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1000}, {"color": "red", "value": 10000}]}, "unit": "short"}},
      "gridPos": {"h": 6, "w": 6, "x": 6, "y": 22},
      "id": 9,
      "options": {"orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [
        {"expr": "redis_connected_clients", "refId": "A"}
      ],
      "title": "Redis Connected Clients",
      "type": "gauge"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 50}, {"color": "green", "value": 90}]}, "unit": "percent"}},
      "gridPos": {"h": 6, "w": 6, "x": 12, "y": 22},
      "id": 10,
      "options": {"orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [
        {"expr": "(redis_memory_used_bytes / redis_memory_max_bytes) * 100", "refId": "A"}
      ],
      "title": "Redis Memory Usage",
      "type": "gauge"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]}, "unit": "short"}},
      "gridPos": {"h": 6, "w": 6, "x": 18, "y": 22},
      "id": 11,
      "options": {"orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [
        {"expr": "sum(rate(tracertm_nats_message_publish_errors_total[5m]))", "refId": "A"}
      ],
      "title": "NATS Message Errors",
      "type": "gauge"
    }
  ],
  "refresh": "5m",
  "schemaVersion": 27,
  "style": "dark",
  "tags": ["tracertm", "infrastructure", "health", "resources"],
  "time": {"from": "now-6h", "to": "now"},
  "title": "Infrastructure Health - Resources & Services",
  "uid": "infrastructure-health",
  "version": 1
}
