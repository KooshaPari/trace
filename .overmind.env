# Overmind configuration (KEY=value only; no shell syntax).
# PATH ensures caddy, uv, bun, temporal are found (Overmind can start with a minimal env).
# Adjust if your Homebrew is elsewhere (Intel: /usr/local/bin first).
OVERMIND_PROCFILE=Procfile
OVERMIND_COLORS=1
PATH=/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin
