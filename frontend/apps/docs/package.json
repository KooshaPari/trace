{
  "name": "@tracertm/docs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --port 3001",
    "prebuild": "bun run scripts/generate-openapi.ts 2>/dev/null || true",
    "build": "NEXT_DISABLE_TURBOPACK=1 next build",
    "start": "next start --port 3001",
    "lint": "bun run format",
    "lint:fix": "bun run format",
    "format": "bun x oxfmt .",
    "openapi": "bun run scripts/generate-openapi.ts",
    "openapi:sync": "bash scripts/sync-openapi.sh",
    "search:index": "bun run scripts/build-search-index.ts",
    "search:benchmark": "bun run scripts/benchmark-search.ts",
    "deploy": "bash scripts/deploy.sh",
    "deploy:preview": "bash scripts/preview-deploy.sh",
    "deploy:prod": "bash scripts/prod-deploy.sh",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:performance": "bun run scripts/performance-audit.ts",
    "test:static": "bun run scripts/test-static-export.ts",
    "lighthouse": "lhci autorun",
    "lighthouse:ci": "lhci autorun --collect.numberOfRuns=1",
    "test:all": "bun run test:performance && bun run test:e2e",
    "audit:bundle": "ANALYZE=true bun run build",
    "build:static": "next build && next export",
    "analyze:cache": "bun run scripts/analyze-cache.ts",
    "optimize:assets": "bun run scripts/optimize-assets.ts",
    "benchmark:assets": "bun run scripts/benchmark-assets.ts",
    "verify:phase_four": "bun run scripts/verify-phase-4.ts",
    "test": "vitest --run",
    "test:coverage": "vitest --run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@alloc/quick-lru": "^5.2.0",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slot": "^1.1.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/mdx": "^2.0.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "fast-uri": "^3.1.0",
    "fumadocs-core": "^16.2.1",
    "fumadocs-mdx": "^14.2.6",
    "fumadocs-openapi": "^10.1.0",
    "fumadocs-ui": "^16.2.1",
    "fuse.js": "^7.1.0",
    "get-nonce": "^1.0.1",
    "hast-util-to-html": "^9.0.5",
    "js-yaml": "^4.1.1",
    "json-schema-traverse": "^1.0.0",
    "lucide-react": "^0.555.0",
    "micromark-factory-destination": "^2.0.1",
    "micromark-factory-label": "^2.0.1",
    "micromark-factory-space": "^2.0.1",
    "micromark-factory-title": "^2.0.1",
    "micromark-factory-whitespace": "^2.0.1",
    "next": "^16.0.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "rimraf": "^6.1.2",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
    "@lhci/cli": "^0.15.1",
    "@next/bundle-analyzer": "^16.1.6",
    "@playwright/test": "^1.58.1",
    "@tanstack/react-virtual": "^3.13.18",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.1",
    "@vitejs/plugin-react": "^4.5.2",
    "@vitest/coverage-v8": "^4.0.14",
    "autoprefixer": "^10.4.22",
    "depcheck": "^1.4.7",
    "postcss": "^8.5.6",
    "svgo": "^3.3.2",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14",
    "webpack-bundle-analyzer": "^5.2.0"
  },
  "overrides": {
    "typescript": "^5.9.3"
  }
}
