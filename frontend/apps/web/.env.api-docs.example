# API Documentation Configuration
# Copy this file to .env.local and update values

# API Base URL
API_URL=http://localhost:8000

# Public URL (used for OAuth redirects and spec URLs)
PUBLIC_URL=http://localhost:3000

# OpenAPI Spec Location
OPENAPI_SPEC_URL=/specs/openapi.json

# Authentication Configuration
AUTH_PERSIST=true
AUTH_TYPE=bearer

# Swagger UI Configuration
SWAGGER_TRY_IT_OUT=true
SWAGGER_FILTER=true
SWAGGER_DEEP_LINKING=true
SWAGGER_DISPLAY_REQUEST_DURATION=true
SWAGGER_DOC_EXPANSION=list

# ReDoc Configuration
REDOC_SCROLL_Y_OFFSET=80
REDOC_HIDE_DOWNLOAD=false
REDOC_DISABLE_SEARCH=false
REDOC_EXPAND_RESPONSES=200,201
REDOC_REQUIRED_PROPS_FIRST=true
REDOC_SORT_PROPS_ALPHABETICALLY=false

# Development
DEBUG=false
LOG_REQUESTS=false
LOG_RESPONSES=false

# Cache Configuration (in seconds)
SPEC_CACHE_TTL=3600
CONFIG_CACHE_TTL=300

# CORS Configuration
CORS_ENABLED=true
CORS_ORIGINS=*
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS,HEAD,PATCH
CORS_HEADERS=Content-Type,Authorization,X-API-Key
