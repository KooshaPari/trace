{
  "name": "@tracertm/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "generate:types": "openapi-typescript public/specs/openapi.json -o src/api/schema.ts",
    "prebuild": "bun run generate:types",
    "predev": "bun run generate:types",
    "postinstall": "node scripts/patch-router-zod4.js",
    "clean:vite": "node -e \"const fs=require('fs');const p='node_modules/.vite';if(fs.existsSync(p)){const ts=new Date().toISOString().replace(/[^0-9]/g,'');const to=p+'.bak.'+ts;fs.renameSync(p,to);console.log('moved',p,'->',to);}else{console.log('no',p);} \"",
    "dev:force": "bun run clean:vite && vite dev --force",
    "dev": "vite dev",
    "dev:benchmark": "node scripts/benchmark-dev-server.js",
    "build": "tsc --build && vite build",
    "build:fast": "vite build",
    "build:clean": "tsc --build --clean && rm -rf dist",
    "preview": "vite preview",
    "populate:mock": "bun run scripts/populate-mock-data.ts",
    "benchmark:layout": "bun run scripts/benchmark-graph-layout.ts",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "storybook:test": "bun --cwd ../storybook run test:vitest --run",
    "chromatic": "chromatic",
    "chromatic:ci": "chromatic --ci --exit-zero-on-changes",
    "lint": "bun run format && bun run lint:fix && oxlint --type-check --type-aware .",
    "lint:fix": "bun run format && oxlint --type-check --type-aware --fix .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "typecheck": "oxlint -f stylish src --promise-plugin --react-plugin --vitest-plugin --jsx-a11y-plugin --react-perf-plugin --node-plugin --jsdoc-plugin --import-plugin --type-check --type-aware",
    "typecheck:oxlint": "oxlint -f stylish src --promise-plugin --react-plugin --vitest-plugin --jsx-a11y-plugin --react-perf-plugin --node-plugin --jsdoc-plugin --import-plugin --type-check --type-aware",
    "test": "vitest",
    "test:browser": "VITEST_BROWSER=1 vitest --run",
    "test:browser:ui": "VITEST_BROWSER=1 vitest --ui",
    "test:a11y": "vitest run src/__tests__/a11y",
    "test:a11y:watch": "vitest watch src/__tests__/a11y",
    "test:a11y:ui": "vitest --ui src/__tests__/a11y",
    "test:a11y:coverage": "vitest run --coverage src/__tests__/a11y",
    "test:security": "vitest run src/__tests__/security",
    "test:security:watch": "vitest watch src/__tests__/security",
    "test:security:ui": "vitest --ui src/__tests__/security",
    "test:security:coverage": "vitest run --coverage src/__tests__/security",
    "test:e2e": "playwright test --config=playwright.config.comprehensive.ts --project=chromium --project=accessibility --project=performance",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:visual": "playwright test --config=playwright-visual.config.ts",
    "test:visual:update": "playwright test --config=playwright-visual.config.ts --update-snapshots",
    "test:visual:ui": "playwright test --config=playwright-visual.config.ts --ui",
    "test:visual:headed": "playwright test --config=playwright-visual.config.ts --headed",
    "test:visual:debug": "playwright test --config=playwright-visual.config.ts --debug",
    "test:visual:report": "playwright show-report playwright-report-visual",
    "test:visual:chromium": "playwright test --config=playwright-visual.config.ts --project=chromium-desktop",
    "test:visual:mobile": "playwright test --config=playwright-visual.config.ts --project=mobile-iphone",
    "test:visual:tablet": "playwright test --config=playwright-visual.config.ts --project=tablet-ipad",
    "test:all": "vitest run && bun run test:e2e && playwright test --config=playwright-visual.config.ts",
    "test:performance": "playwright test --config=playwright.config.comprehensive.ts --project=performance",
    "test:performance:10k": "vitest bench src/__tests__/performance/10k-baseline.bench.ts --run",
    "perf:baseline": "bun run test:performance:10k && bun run scripts/generate-performance-report.ts",
    "perf:report": "bun run scripts/generate-performance-report.ts",
    "generate:test-graph": "bun run scripts/generate-test-graph.ts",
    "verify:10k-baseline": "bun run scripts/manual-verification-test.ts",
    "test:contracts": "vitest run ../../../tests/contracts/consumer",
    "test:contracts:watch": "vitest watch ../../../tests/contracts/consumer",
    "test:contracts:generate": "bun run test:contracts",
    "test:contracts:coverage": "bun run test:contracts && cd ../../../tests/contracts && ./scripts/generate-coverage-report.sh"
  },
  "dependencies": {
    "@axe-core/playwright": "^4.11.0",
