{
	"name": "@tracertm/web",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"populate:mock": "bun run scripts/populate-mock-data.ts",
		"lint": "find src -type f \\( -name '*.ts' -o -name '*.tsx' \\) ! -name 'routeTree.gen.ts' | xargs biome check --files-ignore-unknown=true --assist-enabled=false",
		"lint:fix": "biome check --write --assist-enabled=false .",
		"format": "biome format --write .",
		"typecheck": "tsc -b --noEmit",
		"test": "vitest",
		"test:a11y": "vitest run src/__tests__/a11y",
		"test:a11y:watch": "vitest watch src/__tests__/a11y",
		"test:a11y:ui": "vitest --ui src/__tests__/a11y",
		"test:a11y:coverage": "vitest run --coverage src/__tests__/a11y",
		"test:security": "vitest run src/__tests__/security",
		"test:security:watch": "vitest watch src/__tests__/security",
		"test:security:ui": "vitest --ui src/__tests__/security",
		"test:security:coverage": "vitest run --coverage src/__tests__/security",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:headed": "playwright test --headed",
		"test:e2e:debug": "playwright test --debug",
		"test:e2e:report": "playwright show-report",
		"test:visual": "playwright test --config=playwright-visual.config.ts",
		"test:visual:update": "playwright test --config=playwright-visual.config.ts --update-snapshots",
		"test:visual:ui": "playwright test --config=playwright-visual.config.ts --ui",
		"test:visual:headed": "playwright test --config=playwright-visual.config.ts --headed",
		"test:visual:debug": "playwright test --config=playwright-visual.config.ts --debug",
		"test:visual:report": "playwright show-report playwright-report-visual",
		"test:visual:chromium": "playwright test --config=playwright-visual.config.ts --project=chromium-desktop",
		"test:visual:mobile": "playwright test --config=playwright-visual.config.ts --project=mobile-iphone",
		"test:visual:tablet": "playwright test --config=playwright-visual.config.ts --project=tablet-ipad",
		"test:all": "vitest run && playwright test && playwright test --config=playwright-visual.config.ts"
	},
	"dependencies": {
		"@dnd-kit/core": "^6.3.1",
		"@dnd-kit/sortable": "^10.0.0",
		"@hookform/resolvers": "^5.2.2",
		"@legendapp/state": "^3.0.0-alpha.40",
		"@monaco-editor/react": "^4.7.0",
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-dropdown-menu": "^2.1.16",
		"@radix-ui/react-select": "^2.2.6",
		"@radix-ui/react-tabs": "^1.1.13",
		"@radix-ui/react-toast": "^1.2.2",
		"@radix-ui/react-tooltip": "^1.2.8",
		"@tanstack/react-query": "^5.90.11",
		"@tanstack/react-router": "1.139.14",
		"@tanstack/react-table": "^8.21.3",
		"@tanstack/react-virtual": "^3.13.12",
		"@tracertm/api-client": "workspace:*",
		"@tracertm/state": "workspace:*",
		"@tracertm/types": "workspace:*",
		"@tracertm/ui": "workspace:*",
		"@trpc/client": "^10.45.2",
		"@trpc/react-query": "^10.45.2",
		"@trpc/server": "^10.45.2",
		"@xyflow/react": "^12.9.3",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cytoscape": "^3.30.4",
		"date-fns": "^4.1.0",
		"dompurify": "^3.2.7",
		"esbuild": "^0.27.2",
		"framer-motion": "^11.11.17",
		"lucide-react": "^0.555.0",
		"openapi-fetch": "^0.15.0",
		"react": "^19.2.0",
		"react-cytoscapejs": "^2.0.0",
		"react-dom": "^19.2.0",
		"react-hook-form": "^7.67.0",
		"react-hotkeys-hook": "^4.6.1",
		"recharts": "^2.13.3",
		"redoc": "^2.5.2",
		"sonner": "^2.0.7",
		"swagger-ui-react": "^5.30.3",
		"tailwind-merge": "^3.4.0",
		"zod": "^4.1.13",
		"zustand": "^5.0.9"
	},
	"devDependencies": {
		"@axe-core/react": "^4.11.0",
		"@biomejs/biome": "^2.3.8",
		"@playwright/test": "^1.57.0",
		"@tailwindcss/postcss": "^4.1.17",
		"@tanstack/react-query-devtools": "^5.91.1",
		"@tanstack/react-start": "1.139.14",
		"@tanstack/router-generator": "1.139.14",
		"@tanstack/router-plugin": "1.139.14",
		"@testing-library/react": "^16.0.1",
		"@testing-library/user-event": "^14.6.1",
		"@types/cytoscape": "^3.21.8",
		"@types/dompurify": "^3.2.0",
		"@types/react": "^19.0.1",
		"@types/react-dom": "^19.0.1",
		"@types/swagger-ui-react": "^5.18.0",
		"@vitejs/plugin-react": "^5.1.1",
		"@vitest/coverage-v8": "^4.0.14",
		"autoprefixer": "^10.4.22",
		"axe-core": "^4.11.0",
		"jest-axe": "^10.0.0",
		"jsdom": "^27.2.0",
		"msw": "^2.12.3",
		"postcss": "^8.5.6",
		"redocly": "^1.0.0",
		"swagger-ui-dist": "^5.30.3",
		"tailwindcss": "^4.1.17",
		"typescript": "npm:@typescript/native-preview@7.0.0-dev.20251201.1",
		"vite": "^7.2.4",
		"vitest": "^4.0.14"
	},
	"msw": {
		"workerDirectory": [
			"public"
		]
	}
}
