# ==============================================================================
# FRONTEND ENVIRONMENT VARIABLES - TEMPLATE (Vite)
# ==============================================================================
# Copy this file to .env.local and fill in your actual values
# All variables MUST have VITE_ prefix to be accessible in browser
# ==============================================================================

# -----------------------------------------------------------------------------
# Backend API URLs
# -----------------------------------------------------------------------------
# When using Caddy API Gateway (recommended; rtm dev start → Caddy on :4000).
# Use http://localhost:4000 as the only dev URL; Vite (5173) is internal-only.
VITE_API_URL=http://localhost:4000
VITE_WS_URL=ws://localhost:4000

# Direct backend access (without gateway; not recommended):
# VITE_API_URL=http://localhost:8000
# VITE_WS_URL=ws://localhost:8000

# -----------------------------------------------------------------------------
# WorkOS AuthKit - Authentication
# Get these from: https://dashboard.workos.com/
# Setup guide: https://workos.com/docs/authkit/react
# 
# For React: AuthKit handles token storage internally (localStorage in dev, HttpOnly cookies in prod)
# redirectUri is automatically set from window.location.origin + /auth/callback
# devMode toggles automatically (true in dev, false in production)
# 
# apiHostname (PROD ONLY): Set to your custom Authentication API domain
#   Example: auth.tracertm.com
#   This is NOT required in development (devMode uses localStorage)
#   Only needed in production for HttpOnly cookie context
# 
# See: https://workos.com/docs/authkit/react/python
# See: https://workos.com/docs/custom-domains/authkit
# See: https://workos.com/docs/custom-domains/auth-api
# 
# Staging Example:
#   VITE_WORKOS_CLIENT_ID=client_01K4KYZR40RK7R9X3PPB5SEJ66
#   VITE_WORKOS_AUTH_DOMAIN=auth.example.com (production only)
# 
# Development: Leave VITE_WORKOS_AUTH_DOMAIN empty
# Production: Set VITE_WORKOS_AUTH_DOMAIN to your custom domain
# 
VITE_WORKOS_CLIENT_ID=client_XXXXXXXXXX
VITE_WORKOS_AUTH_DOMAIN=

# -----------------------------------------------------------------------------
# Development Tools
# -----------------------------------------------------------------------------
# Mock Service Worker (MSW) for API mocking during development
VITE_ENABLE_MSW=true

# Logging level (debug, info, warn, error)
VITE_LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
# Graph visualization features
VITE_ENABLE_GRAPH_VIEW=true

# Real-time synchronization via WebSocket
VITE_ENABLE_REALTIME_SYNC=true

# AI-powered suggestions (requires backend AI configuration)
VITE_ENABLE_AI_SUGGESTIONS=false

# Export functionality
VITE_ENABLE_EXPORT=true

# Import functionality
VITE_ENABLE_IMPORT=true

# Real-time collaboration features
VITE_ENABLE_COLLABORATION=false

# -----------------------------------------------------------------------------
# Performance & Analytics (Optional)
# -----------------------------------------------------------------------------
# Enable performance monitoring
# VITE_ENABLE_PERFORMANCE_MONITORING=false

# Analytics provider (e.g., "plausible", "google", "none")
# VITE_ANALYTICS_PROVIDER=none
# VITE_ANALYTICS_DOMAIN=tracertm.com

# -----------------------------------------------------------------------------
# Sentry Error Tracking (Optional)
# -----------------------------------------------------------------------------
# Get these from: https://sentry.io/settings/projects/
# Create a new project in Sentry, then copy the DSN from Project Settings
# VITE_SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx
# VITE_SENTRY_ORG=your-org-name
# VITE_SENTRY_PROJECT=tracertm-frontend

# For source map upload (production builds only):
# Generate an auth token at: https://sentry.io/settings/account/api/auth-tokens/
# Required scopes: project:releases, project:write
# VITE_SENTRY_AUTH_TOKEN=your-auth-token

# Release tracking (optional)
# VITE_APP_VERSION=1.0.0
# VITE_BUILD_ID=local

# -----------------------------------------------------------------------------
# Build Configuration (Optional)
# -----------------------------------------------------------------------------
# Source maps in production (true for debugging, false for smaller bundles)
# VITE_SOURCEMAPS=false

# Bundle analysis
# VITE_ANALYZE_BUNDLE=false
