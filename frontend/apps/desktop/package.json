{
  "name": "@tracertm/desktop",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-builder",
    "package:mac": "electron-builder --mac",
    "package:win": "electron-builder --win",
    "package:linux": "electron-builder --linux",
    "test": "vitest --run",
    "test:coverage": "vitest --run --coverage",
    "test:watch": "vitest",
    "lint": "bun x oxlint -c .oxlintrc.json . --ignore-pattern \"**/__tests__/**\" --ignore-pattern \"**/*.test.ts\" --ignore-pattern \"**/*.spec.ts\" --ignore-pattern \"**/*.mjs\"",
    "lint:fix": "bun x oxlint -c .oxlintrc.json --fix . --ignore-pattern \"**/__tests__/**\" --ignore-pattern \"**/*.test.ts\" --ignore-pattern \"**/*.spec.ts\" --ignore-pattern \"**/*.mjs\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tracertm/types": "workspace:*",
    "electron-updater": "^6.6.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^22.9.0",
    "@vitest/coverage-v8": "^4.0.14",
    "electron": "^39.2.4",
    "electron-builder": "^26.0.12",
    "electron-vite": "^4.0.1",
    "tailwindcss": "^4.1.17",
    "typescript": "npm:@typescript/native-preview@7.0.0-dev.20251201.1",
    "vite": "^7.2.4",
    "vitest": "^4.0.14"
  },
  "build": {
    "appId": "com.tracertm.desktop",
    "productName": "TraceRTM",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "resources/icon.icns"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "resources/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "resources/icon.png"
    }
  }
}
