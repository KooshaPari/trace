{
  "name": "@tracertm/storybook",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NODE_NO_WARNINGS=1 storybook dev -p 6006 --no-open",
    "build": "storybook build",
    "test": "bun run test:vitest --run",
    "test:vitest": "vitest --config vitest.config.ts",
    "test:vitest:ui": "vitest --config vitest.config.ts --ui",
    "serve:static": "http-server storybook-static -p 6006 -s",
    "test:ci": "bash scripts/test-storybook-ci.sh",
    "dev:node22": "NODE_OPTIONS=--no-experimental-require-module storybook dev -p 6006",
    "build:node22": "NODE_OPTIONS=--no-experimental-require-module storybook build"
  },
  "dependencies": {
    "@tracertm/ui": "workspace:*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@storybook/addon-a11y": "8.6.14",
    "@storybook/addon-coverage": "3.0.0",
    "@storybook/addon-docs": "8.6.14",
    "@storybook/addon-themes": "8.6.14",
    "@storybook/react": "8.6.14",
    "@storybook/react-dom-shim": "8.6.14",
    "@storybook/react-vite": "8.6.14",
    "@types/react": "^19.0.1",
    "@vitest/browser": "4.0.18",
    "@vitest/browser-playwright": "4.0.18",
    "@vitest/coverage-v8": "4.0.18",
    "@vitest/ui": "4.0.18",
    "chromatic": "^15.0.0",
    "http-server": "^14.1.1",
    "playwright": "^1.55.0",
    "rollup": "^4.30.0",
    "storybook": "8.6.17",
    "typescript": "npm:@typescript/native-preview@7.0.0-dev.20251201.1",
    "vite": "^8.0.3",
    "vitest": "^4.0.14",
    "wait-on": "^8.0.2"
  }
}
