# TraceRTM Frontend Environment Variables

# API Configuration
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000

# Feature Flags
VITE_ENABLE_MSW=true
VITE_ENABLE_GRAPH_VIEW=true
VITE_ENABLE_REALTIME_SYNC=true
VITE_ENABLE_AI_SUGGESTIONS=false
VITE_ENABLE_EXPORT=true
VITE_ENABLE_IMPORT=true
VITE_ENABLE_COLLABORATION=false

# Development
VITE_LOG_LEVEL=debug

# Figma Integration (Optional)
VITE_FIGMA_ACCESS_TOKEN=
VITE_FIGMA_FILE_ID=
