{
	"name": "tracertm-frontend",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"postinstall": "./scripts/patch-jiti.sh && node scripts/patch-compose-refs.js",
		"dev": "turbo dev --filter=@tracertm/web",
		"dev:all": "turbo dev --parallel",
		"dev:docs": "turbo dev --filter=@tracertm/docs",
		"dev:storybook": "turbo dev --filter=@tracertm/storybook",
		"dev:desktop": "turbo dev --filter=@tracertm/desktop",
		"build": "turbo build --concurrency=8 --filter=!@tracertm/storybook",
		"build:web": "turbo build --filter=@tracertm/web",
		"build:docs": "turbo build --filter=@tracertm/docs",
		"build:storybook": "turbo build --filter=@tracertm/storybook",
		"build:parallel": "turbo build --parallel --concurrency=8",
		"test": "turbo test --concurrency=4",
		"test:parallel": "turbo test --parallel --concurrency=4",
		"test:perf": "bun scripts/run-all-performance-tests.ts",
		"test:perf:build": "bun scripts/test-build-performance.ts",
		"test:perf:runtime": "bun scripts/test-runtime-performance.ts",
		"test:perf:validate": "bun scripts/validate-optimizations.ts",
		"lint": "oxlint .",
		"lint:fix": "oxlint --fix .",
		"lint:report-unused-disable": "oxlint --report-unused-disable-directives .",
		"lint:oxc": "oxlint .",
		"lint:biome": "biome check .",
		"lint:stylelint": "stylelint \"apps/**/*.css\" \"packages/**/*.css\"",
		"lint:stylelint:fix": "stylelint \"apps/**/*.css\" \"packages/**/*.css\" --fix",
		"lint:turbo": "turbo lint --concurrency=8",
		"format": "oxfmt .",
		"format:check": "oxfmt --check .",
		"format:biome": "biome format --write .",
		"format:biome:check": "biome format .",
		"check": "oxlint .",
		"check:fix": "oxlint --fix .",
		"typecheck": "oxlint --type-check --type-aware .",
		"typecheck:type-aware-only": "oxlint --type-aware .",
		"typecheck:report-unused-disable": "oxlint --type-check --type-aware --report-unused-disable-directives .",
		"quality": "bun run lint && bun run lint:stylelint && bun run typecheck && bun run build && bun run test",
		"clean": "turbo clean && rm -rf node_modules",
		"ci:build": "turbo build typecheck lint --concurrency=8 --output-logs=hash-only",
		"ci:test": "turbo test --concurrency=4 --output-logs=new-only",
		"ci:perf": "bun scripts/run-all-performance-tests.ts",
		"generate:stories": "bun run tools/storybook-generator/generate-stories.ts",
		"figma:sync": "bun run tools/figma-generator/sync-designs.ts",
		"figma:push": "bun run tools/figma-generator/sync-designs.ts push",
		"figma:pull": "bun run tools/figma-generator/sync-designs.ts pull",
		"figma:export": "bun run tools/figma-generator/generate-figma.ts",
		"figma:conflicts": "bun run tools/figma-generator/sync-designs.ts conflicts",
		"figma:export-tokens": "bun run tools/figma-generator/sync-designs.ts export-tokens",
		"figma:upload": "bun run tools/figma-generator/sync-designs.ts upload"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.8",
		"@tanstack/router-generator": "1.120.20",
		"@tanstack/router-plugin": "1.120.20",
		"@types/bun": "^1.3.3",
		"@types/node": "^22.10.2",
		"@types/rbush": "^4.0.0",
		"@vitejs/plugin-react-swc": "^4.2.2",
		"figma-api": "^1.11.0",
		"glob": "^11.0.0",
		"oxfmt": "^0.27.0",
		"oxlint": "^1.42.0",
		"oxlint-tsgolint": "^0.11.4",
		"stylelint": "^17.1.0",
		"stylelint-config-recommended": "^18.0.0",
		"stylelint-config-tailwindcss": "^1.0.1",
		"ts-morph": "^24.0.0",
		"turbo": "^2.6.1",
		"vite-plugin-checker": "^0.12.0",
		"typescript": "5.7.2",
		"yaml": "^2.6.1"
	},
	"packageManager": "bun@1.1.38",
	"overrides": {
		"@biomejs/biome": "^2.3.13",
		"@playwright/test": "^1.50.3",
		"@radix-ui/react-accordion": "^1.2.12",
		"@radix-ui/react-collapsible": "^1.1.12",
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-dropdown-menu": "^2.1.16",
		"@radix-ui/react-scroll-area": "^1.2.10",
		"@radix-ui/react-select": "^2.2.6",
		"@radix-ui/react-slot": "^1.2.4",
		"@radix-ui/react-tabs": "^1.1.13",
		"@radix-ui/react-toast": "^1.2.2",
		"@radix-ui/react-tooltip": "^1.2.8",
		"@storybook/react": "10.2.1",
		"@storybook/react-dom-shim": "10.2.1",
		"@storybook/react-vite": "^10.2.1",
		"@tanstack/react-query": "^5.90.14",
		"@tanstack/react-router": "^1.157.16",
		"@tanstack/react-table": "^8.21.3",
		"@tanstack/react-virtual": "^3.13.12",
		"@testing-library/react": "^16.3.0",
		"@types/node": "^22.10.7",
		"@types/react": "^19.2.8",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "5.1.2",
		"@vitejs/plugin-react-swc": "^4.2.2",
		"clsx": "^2.1.1",
		"date-fns": "^4.1.0",
		"esbuild": "^0.27.2",
		"lucide-react": "^0.563.0",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"react-hook-form": "^7.71.1",
		"react-refresh": "^0.18.0",
		"tailwind-merge": "^3.4.0",
		"turbo": "^2.6.1",
		"typescript": "npm:@typescript/native-preview@7.0.0-dev.20251201.1",
		"vite": "^8.0.0-beta.11",
		"vitest": "^3.0.6",
		"zod": "4.3.6"
	},
	"dependencies": {
		"@tanstack/react-router": "^1.157.16",
		"@vitejs/plugin-react": "5.1.2",
		"fast-glob": "^3.3.3",
		"rbush": "^4.0.1",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"vite": "^8.0.0-beta.11"
	}
}
