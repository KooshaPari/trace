{
	"$schema": "./node_modules/oxlint/configuration_schema.json",
	"ignorePatterns": [
		"**/node_modules/**",
		"**/dist/**",
		"**/.turbo/**",
		"**/routeTree.gen.ts",
		"**/api/schema.ts",
		"**/*.gen.ts"
	],
	"plugins": [
		"eslint",
		"typescript",
		"unicorn",
		"oxc",
		"react",
		"react-perf",
		"import",
		"jsx-a11y",
		"promise",
		"vitest"
	],
	"env": {
		"browser": true,
		"es2022": true,
		"builtin": true
	},
	"categories": {
		"correctness": "error",
		"suspicious": "error",
		"pedantic": "warn",
		"style": "warn",
		"restriction": "warn",
		"perf": "warn",
		"nursery": "off"
	},
	"rules": {
		"react/react-in-jsx-scope": "off",
		"import/no-cycle": ["error", { "maxDepth": 3 }],
		"import/no-duplicates": "warn",
		"typescript/no-floating-promises": "error",
		"typescript/no-misused-promises": "error",
		"typescript/no-unsafe-assignment": "warn",
		"typescript/no-unsafe-call": "warn",
		"typescript/no-unsafe-member-access": "warn",
		"typescript/no-unsafe-return": "warn",
		"eslint/eqeqeq": ["error", "always"],
		"react/self-closing-comp": ["error", { "component": true, "html": false }]
	},
	"settings": {
		"react": { "version": "18" }
	},
	"overrides": [
		{
			"files": ["**/*.test.ts", "**/*.test.tsx", "**/*.spec.ts", "**/*.spec.tsx", "**/*.smoke.test.tsx", "**/__tests__/**", "**/e2e/**/*.ts"],
			"rules": {
				"typescript/no-explicit-any": "off",
				"typescript/no-non-null-assertion": "off",
				"typescript/explicit-function-return-type": "off",
				"typescript/explicit-module-boundary-types": "off",
				"eslint/no-magic-numbers": "off",
				"eslint/sort-keys": "off",
				"eslint/func-style": "off",
				"eslint/sort-imports": "off",
				"eslint/no-undefined": "off",
				"eslint/no-void": "off",
				"eslint/no-empty-function": "off",
				"eslint/no-await-in-loop": "off",
				"eslint/no-inline-comments": "off",
				"eslint/no-plusplus": "off",
				"eslint/no-console": "off",
				"eslint/max-lines-per-function": "off",
				"eslint/max-lines": "off",
				"eslint/max-statements": "off",
				"oxc/no-async-await": "off",
				"oxc/no-optional-chaining": "off",
				"eslint/id-length": "off",
				"eslint/prefer-destructuring": "off",
				"unicorn/filename-case": "off",
				"unicorn/prefer-dom-node-append": "off",
				"unicorn/no-array-for-each": "off",
				"vitest/prefer-to-be-truthy": "off",
				"vitest/prefer-to-be-falsy": "off",
				"vitest/consistent-test-filename": "off"
			}
		},
		{
			"files": ["analyze-deps.js", "find-unused-deps.js", "scripts/**/*.js", "scripts/**/*.ts", "tools/**/*.ts"],
			"rules": {
				"oxc/no-async-await": "off",
				"oxc/no-rest-spread-properties": "off",
				"unicorn/no-null": "off",
				"unicorn/no-array-for-each": "off",
				"eslint/max-lines-per-function": "off",
				"eslint/complexity": "off",
				"eslint/sort-imports": "off"
			}
		},
		{
			"files": ["apps/web/src/router.tsx"],
			"rules": {
				"import/group-exports": "off",
				"import/no-named-export": "off",
				"eslint/func-style": "off",
				"eslint/sort-keys": "off"
			}
		},
		{
			"files": ["apps/**/src/**/*.ts", "apps/**/src/**/*.tsx", "packages/**/src/**/*.ts", "packages/**/src/**/*.tsx"],
			"rules": {
				"eslint/func-style": "off",
				"eslint/curly": "off",
				"eslint/no-ternary": "off",
				"eslint/capitalized-comments": "off",
				"eslint/arrow-body-style": "off",
				"eslint/max-lines": "off",
				"eslint/max-params": "off",
				"eslint/sort-imports": "off",
				"eslint/sort-keys": "off",
				"eslint/new-cap": "off",
				"import/group-exports": "off",
				"import/no-named-export": "off",
				"import/no-default-export": "off",
				"import/exports-last": "off",
				"typescript/explicit-function-return-type": "off",
				"typescript/explicit-module-boundary-types": "off",
				"unicorn/numeric-separators-style": "off",
				"unicorn/no-zero-fractions": "off",
				"unicorn/no-null": "off",
				"oxc/no-async-await": "off",
				"react/jsx-filename-extension": "off",
				"react/jsx-max-depth": "off",
				"oxc/no-optional-chaining": "off",
				"oxc/no-rest-spread-properties": "off",
				"eslint/no-magic-numbers": "off",
				"eslint/no-undefined": "off",
				"eslint/no-void": "off",
				"eslint/id-length": "off",
				"unicorn/filename-case": "off",
				"eslint-plugin-react-perf/jsx-no-new-function-as-prop": "off",
				"eslint-plugin-react-perf/jsx-no-new-object-as-prop": "off",
				"typescript/array-type": "off",
				"eslint/no-negated-condition": "off",
				"eslint/no-nested-ternary": "off",
				"eslint/prefer-destructuring": "off",
				"eslint/no-plusplus": "off",
				"eslint/no-implicit-coercion": "off",
				"eslint/no-else-return": "off",
				"eslint-plugin-unicorn/no-nested-ternary": "off",
				"eslint-plugin-unicorn/prefer-spread": "off",
				"eslint-plugin-unicorn/prefer-number-properties": "off",
				"eslint-plugin-unicorn/prefer-at": "off",
				"eslint-plugin-unicorn/no-useless-collection-argument": "off",
				"eslint-plugin-unicorn/switch-case-braces": "off",
				"eslint-plugin-unicorn/prefer-query-selector": "off",
				"eslint-plugin-unicorn/prefer-global-this": "off",
				"eslint-plugin-react-hooks/rules-of-hooks": "off",
				"eslint-plugin-react/no-set-state": "off",
				"eslint-plugin-react/button-has-type": "off",
				"eslint-plugin-react/jsx-handler-names": "off",
				"eslint-plugin-import/consistent-type-specifier-style": "off",
				"eslint-plugin-import/max-dependencies": "off",
				"eslint-plugin-react/no-array-index-key": "off",
				"eslint-plugin-unicorn/no-array-for-each": "off",
				"oxc/no-map-spread": "off",
				"eslint/no-inline-comments": "off",
				"typescript/no-explicit-any": "off"
			}
		},
		{
			"files": ["apps/docs/**/*.tsx", "apps/docs/**/*.ts"],
			"rules": {
				"import/no-default-export": "off",
				"react/jsx-filename-extension": "off",
				"react/jsx-max-depth": ["warn", { "max": 4 }],
				"eslint/sort-keys": "off",
				"eslint/sort-imports": "off",
				"eslint/new-cap": "off",
				"react/only-export-components": "off"
			}
		},
		{
			"files": ["**/vite.config.mjs", "**/vite.config.ts", "**/vite.config.js", "**/nitro.config.ts", "**/svgo.config.js", "**/next.config.*", "**/*.config.js", "**/*.config.ts", "**/*.config.mjs"],
			"rules": {
				"import/no-default-export": "off",
				"import/no-anonymous-default-export": "off",
				"eslint/max-lines": "off",
				"eslint/complexity": "off",
				"eslint/max-lines-per-function": "off",
				"eslint/max-statements": "off",
				"eslint/sort-keys": "off",
				"eslint/capitalized-comments": "off",
				"eslint/no-inline-comments": "off",
				"eslint/no-ternary": "off",
				"eslint/curly": "off",
				"eslint/new-cap": "off",
				"eslint/no-undefined": "off",
				"eslint/sort-imports": "off",
				"eslint/require-await": "off",
				"typescript/no-var-requires": "off"
			}
		}
	]
}
