{
	"$schema": "https://oxc.rs/schema.json",
	"plugins": ["react", "unicorn", "jsx-a11y", "react-perf", "import"],
	"rules": {
		"typescript/no-explicit-any": "error",
		"typescript/explicit-function-return-type": "error",
		"typescript/explicit-module-boundary-types": "error",
		"typescript/no-unsafe-assignment": "error",
		"typescript/no-unsafe-member-access": "error",
		"typescript/no-unsafe-call": "error",
		"typescript/no-unsafe-return": "error",
		"typescript/strict-boolean-expressions": "error",
		"typescript/no-floating-promises": "error",
		"typescript/await-thenable": "error",
		"typescript/no-misused-promises": "error",
		"typescript/prefer-nullish-coalescing": "error",
		"typescript/prefer-optional-chain": "error",

		"eslint/sort-imports": ["error", {
			"ignoreCase": false,
			"ignoreDeclarationSort": false,
			"ignoreMemberSort": false,
			"memberSyntaxSortOrder": ["none", "all", "multiple", "single"]
		}],
		"eslint/sort-keys": ["error", "asc", {
			"caseSensitive": true,
			"natural": true,
			"minKeys": 2
		}],
		"import/order": ["error", {
			"groups": [
				"builtin",
				"external",
				"internal",
				"parent",
				"sibling",
				"index",
				"object",
				"type"
			],
			"pathGroups": [
				{
					"pattern": "@/**",
					"group": "internal"
				}
			],
			"alphabetize": {
				"order": "asc",
				"caseInsensitive": false
			}
		}],
		"eslint/func-style": ["error", "expression", {
			"allowArrowFunctions": true
		}],

		"eslint/id-length": ["error", {
			"min": 2,
			"max": 50,
			"exceptions": ["i", "j", "k", "x", "y", "z", "_"],
			"properties": "never",
			"exceptionPatterns": ["^[a-z]$"]
		}],
		"unicorn/prevent-abbreviations": ["warn", {
			"checkFilenames": false,
			"allowList": {
				"args": true,
				"Args": true,
				"db": true,
				"Db": true,
				"env": true,
				"Env": true,
				"params": true,
				"Params": true,
				"props": true,
				"Props": true,
				"ref": true,
				"Ref": true
			}
		}],
		"unicorn/filename-case": ["error", {
			"cases": {
				"camelCase": true,
				"pascalCase": true,
				"kebabCase": true
			}
		}],

		"eslint/max-lines-per-function": ["error", {
			"max": 50,
			"skipBlankLines": true,
			"skipComments": true,
			"IIFEs": true
		}],
		"eslint/max-params": ["error", 3],
		"eslint/max-depth": ["error", 3],
		"eslint/max-nested-callbacks": ["error", 3],
		"complexity": ["error", 10],
		"eslint/max-statements": ["error", 15],

		"eslint/no-magic-numbers": ["error", {
			"ignore": [0, 1, -1],
			"ignoreArrayIndexes": true,
			"ignoreDefaultValues": true,
			"enforceConst": true,
			"detectObjects": false
		}],

		"react/jsx-max-depth": ["error", { "max": 4 }],
		"react-perf/jsx-no-new-object-as-prop": "error",
		"react-perf/jsx-no-new-array-as-prop": "error",
		"react-perf/jsx-no-new-function-as-prop": "error",
		"react/jsx-no-leaked-render": "error",
		"react-hooks/exhaustive-deps": "error",
		"react/jsx-no-useless-fragment": "error",
		"react/no-array-index-key": "warn",
		"react/jsx-key": "error",
		"react/jsx-no-duplicate-props": "error",

		"import/no-cycle": ["error", {
			"maxDepth": 3,
			"ignoreExternal": true
		}],
		"import/no-self-import": "error",
		"import/no-useless-path-segments": "error",
		"import/no-duplicates": "error",
		"import/first": "error",
		"import/newline-after-import": "error",

		"import/no-default-export": "warn",
		"import/no-named-export": "off",
		"import/prefer-default-export": "off",
		"import/exports-last": "off",

		"eslint/no-ternary": "off",
		"unicorn/no-nested-ternary": "error",
		"eslint/multiline-ternary": ["error", "always-multiline"],
		"eslint/no-unneeded-ternary": "error",

		"oxc/no-optional-chaining": "off",
		"oxc/no-rest-spread-properties": "off",
		"oxc/no-async-await": "off",
		"unicorn/prefer-spread": "error",
		"unicorn/prefer-modern-math-apis": "error",
		"eslint/prefer-exponentiation-operator": "error",

		"eslint/no-throw-literal": "error",
		"unicorn/error-message": "error",
		"unicorn/prefer-type-error": "error",

		"eslint/no-console": "warn",
		"eslint/no-debugger": "error",
		"eslint/no-alert": "error",
		"eslint/eqeqeq": ["error", "always"],
		"eslint/no-eval": "error",
		"eslint/no-implied-eval": "error",
		"eslint/no-new-func": "error",
		"eslint/no-script-url": "error",
		"eslint/no-void": "error",

		"eslint/no-inline-comments": "off",
		"eslint/line-comment-position": "off",
		"eslint/capitalized-comments": "off",
		"eslint/multiline-comment-style": "off",
		"eslint/init-declarations": "off"
	},

	"overrides": [
		{
			"files": ["**/*.test.ts", "**/*.test.tsx", "**/*.spec.ts", "**/*.spec.tsx", "**/*.bench.ts"],
			"rules": {
				"eslint/max-lines-per-function": "off",
				"eslint/max-statements": "off",
				"eslint/no-magic-numbers": "off",
				"typescript/no-explicit-any": "warn",
				"eslint/max-nested-callbacks": "off",
				"eslint/id-length": ["error", {
					"min": 1,
					"exceptions": ["i", "j", "k", "x", "y", "z", "a", "b", "c", "_"]
				}]
			}
		},
		{
			"files": ["**/routes/**/*.tsx", "**/routes/**/*.ts"],
			"rules": {
				"import/no-default-export": "off",
				"typescript/explicit-function-return-type": "off"
			}
		},
		{
			"files": ["**/*.config.ts", "**/*.config.js", "**/vite.config.*", "**/vitest.config.*"],
			"rules": {
				"import/no-default-export": "off",
				"eslint/no-magic-numbers": "off"
			}
		},
		{
			"files": ["**/e2e/**/*.ts", "**/e2e/**/*.tsx"],
			"rules": {
				"eslint/max-lines-per-function": ["error", 100],
				"eslint/max-statements": ["error", 25],
				"typescript/no-explicit-any": "warn"
			}
		},
		{
			"files": ["**/components/forms/**/*.tsx", "**/components/forms/**/*.ts"],
			"rules": {
				"react/jsx-max-depth": ["error", { "max": 6 }],
				"eslint/max-lines-per-function": ["error", { "max": 100, "skipBlankLines": true, "skipComments": true }],
				"complexity": ["error", 20],
				"eslint/max-statements": ["error", 30],
				"eslint/no-magic-numbers": ["error", {
					"ignore": [0, 1, -1, 100, 255, 500, 1000, 2000, 5000],
					"ignoreArrayIndexes": true,
					"ignoreDefaultValues": true,
					"enforceConst": true,
					"detectObjects": false
				}],
				"react-perf/jsx-no-new-function-as-prop": "warn"
			}
		}
	]
}
