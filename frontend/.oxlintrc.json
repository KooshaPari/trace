{
	"$schema": "https://oxc.rs/schema.json",
	"plugins": ["react", "unicorn", "jsx-a11y", "react-perf", "import"],
	"rules": {
		"typescript/no-explicit-any": "error",
		"typescript/explicit-function-return-type": "error",
		"typescript/explicit-module-boundary-types": "error",
		"typescript/no-unsafe-assignment": "error",
		"typescript/no-unsafe-member-access": "error",
		"typescript/no-unsafe-call": "error",
		"typescript/no-unsafe-return": "error",
		"typescript/strict-boolean-expressions": "error",
		"typescript/no-floating-promises": "error",
		"typescript/await-thenable": "error",
		"typescript/no-misused-promises": "error",
		"typescript/prefer-nullish-coalescing": "error",
		"typescript/prefer-optional-chain": "error",

		"eslint/sort-imports": "off",
		"eslint/sort-keys": "off",
		"eslint/func-style": "off",
		"eslint/id-length": "off",
		"eslint/no-void": "off",
		"eslint/no-alert": "off",
		"eslint/eqeqeq": "off",
		"unicorn/no-nested-ternary": "off",
		"eslint/prefer-exponentiation-operator": "off",
		"unicorn/prefer-modern-math-apis": "off",
		"unicorn/filename-case": "off",
		"import/order": ["error", {
			"groups": [
				"builtin",
				"external",
				"internal",
				"parent",
				"sibling",
				"index",
				"object",
				"type"
			],
			"pathGroups": [
				{
					"pattern": "@/**",
					"group": "internal"
				}
			],
			"alphabetize": {
				"order": "asc",
				"caseInsensitive": false
			}
		}],

		"unicorn/prevent-abbreviations": ["warn", {
			"checkFilenames": false,
			"allowList": {
				"args": true,
				"Args": true,
				"db": true,
				"Db": true,
				"env": true,
				"Env": true,
				"params": true,
				"Params": true,
				"props": true,
				"Props": true,
				"ref": true,
				"Ref": true
			}
		}],
		"unicorn/filename-case": ["error", {
			"cases": {
				"camelCase": true,
				"pascalCase": true,
				"kebabCase": true
			}
		}],

		"eslint/max-lines-per-function": ["error", {
			"max": 100,
			"skipBlankLines": true,
			"skipComments": true,
			"IIFEs": true
		}],
		"eslint/max-params": "off",
		"eslint/max-statements": "off",
		"complexity": "off",

		"eslint/no-magic-numbers": "off",

		"react/jsx-max-depth": ["error", { "max": 15 }],
		"react-perf/jsx-no-new-object-as-prop": "off",
		"react-perf/jsx-no-new-array-as-prop": "off",
		"react-perf/jsx-no-new-function-as-prop": "off",
		"react/jsx-no-leaked-render": "error",
		"react-hooks/exhaustive-deps": "warn",
		"react/jsx-no-useless-fragment": "error",
		"react/no-array-index-key": "warn",
		"react/jsx-key": "error",
		"react/jsx-no-duplicate-props": "error",

		"import/no-cycle": ["error", {
			"maxDepth": 3,
			"ignoreExternal": true
		}],
		"import/no-self-import": "error",
		"import/no-useless-path-segments": "error",
		"import/no-duplicates": "error",
		"import/first": "error",
		"import/newline-after-import": "error",

		"import/no-default-export": "warn",
		"import/no-named-export": "off",
		"import/prefer-default-export": "off",
		"import/exports-last": "off",

		"eslint/no-ternary": "off",
		"unicorn/no-nested-ternary": "off",
		"eslint/multiline-ternary": ["error", "always-multiline"],
		"eslint/no-unneeded-ternary": "error",

		"oxc/no-optional-chaining": "off",
		"oxc/no-rest-spread-properties": "off",
		"oxc/no-async-await": "off",
		"unicorn/prefer-spread": "off",
		"unicorn/prefer-modern-math-apis": "off",
		"eslint/prefer-exponentiation-operator": "off",

		"eslint/no-throw-literal": "error",
		"unicorn/error-message": "error",
		"unicorn/prefer-type-error": "error",

		"eslint/no-console": "off",
		"eslint/no-debugger": "error",
		"eslint/eqeqeq": "off",
		"eslint/no-eval": "error",
		"eslint/no-implied-eval": "error",
		"eslint/no-new-func": "error",
		"eslint/no-script-url": "error",
		"eslint/no-void": "off",
		"eslint/no-unused-expressions": "off",
		"eslint/no-unused-vars": "off",

		"eslint-plugin-unicorn/filename-case": "off",
		"eslint/no-self-assign": "off",
		"eslint/no-useless-catch": "off",
		"eslint/no-ex-assign": "off",
		"eslint/no-script-url": "off",
		"react-hooks/exhaustive-deps": "off",
		"react/no-array-index-key": "off",
		"import/no-default-export": "off",
		"react/perf-jsx-no-new-function-as-prop": "off",
		"eslint-plugin-jsx-a11y/label-has-associated-control": "off",
		"eslint-plugin-jsx-a11y/click-events-have-key-events": "off",
		"eslint-plugin-jsx-a11y/no-noninteractive-element-interactions": "off",
		"eslint-plugin-jsx-a11y/anchor-is-valid": "off",

		"eslint/no-inline-comments": "off",
		"eslint/line-comment-position": "off",
		"eslint/capitalized-comments": "off",
		"eslint/multiline-comment-style": "off",
		"eslint/init-declarations": "off"
	},

