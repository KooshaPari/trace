# Figma Integration Configuration
# Copy this to .env.local and fill in your values

# Required: Your Figma personal access token
# Get it from: https://www.figma.com/developers/api#authentication
# 1. Go to Account Settings in Figma
# 2. Scroll to Personal Access Tokens
# 3. Click "Generate new token"
# 4. Copy the token and paste it here
FIGMA_ACCESS_TOKEN=figd_your_figma_access_token_here

# Required: The file key from your Figma file URL
# Example: https://www.figma.com/file/ABC123XYZ/Design-System
# File key would be: ABC123XYZ
FIGMA_FILE_KEY=your_file_key_here

# Optional: story.to.design integration
# Enable this for Storybook → Figma sync
STORY_TO_DESIGN_URL=https://api.story.to.design/v1/sync
STORY_TO_DESIGN_ENABLED=true

# Optional: Rate limiting configuration
# Maximum requests per time window (default: 100)
FIGMA_RATE_LIMIT_REQUESTS=100
# Time window in milliseconds (default: 60000 = 1 minute)
FIGMA_RATE_LIMIT_MS=60000

# Optional: Output configuration
# Where to save generated files (default: .figma-output)
FIGMA_OUTPUT_DIR=.figma-output
# Output format: plugin, story-to-design, or both (default: both)
FIGMA_OUTPUT_FORMAT=both

# Optional: Sync configuration
# Automatically sync on component changes (default: false)
FIGMA_AUTO_SYNC=false
# How to resolve conflicts: local, remote, or manual (default: manual)
FIGMA_CONFLICT_RESOLUTION=manual
