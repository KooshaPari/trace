{
  "name": "tracertm-workspace",
  "scripts": {
    "dev": "make dev",
    "dev:tui": "make dev-tui",
    "dev:down": "make dev-down",
    "dev:logs": "make dev-logs",
    "dev:status": "make dev-status",
    "dev:storybook": "cd frontend/apps/storybook && bun run dev",
    "build": "cd frontend && bunx turbo build --no-daemon --filter=!@tracertm/storybook",
    "quality": "make quality",
    "check": "make check",
    "lint": "cd frontend && bun run lint",
    "lint:all": "make lint",
    "lint:frontend": "cd frontend && bun run lint",
    "lint:fix": "make format && cd frontend && bun run format",
    "type-check": "make type-check",
    "typecheck": "cd frontend && bun run typecheck",
    "format": "make format",
    "format:check": "make lint-python",
    "test": "make test",
    "test:frontend": "cd frontend && bun test",
    "test:unit": "make test-unit",
    "test:e2e": "make test-e2e",
    "test:go": "make test-go",
    "test:python": "make test-python",
    "test:python:parallel": "make test-python-parallel",
    "test:coverage": "make test-python",
    "test:integration": "make test-integration",
    "lint:go": "make lint-go",
    "lint:python": "make lint-python",
    "lint:python:fix": "make lint-python-fix",
    "format:python": "make py-format",
    "format:go": "make go-format",
    "type-check:ty": "make type-check-ty",
    "clean": "make clean",
    "db:migrate": "make db-migrate",
    "db:rollback": "make db-rollback",
    "db:reset": "make db-reset",
    "db:shell": "make db-shell",
    "generate:openapi:python": "./scripts/shell/generate-openapi-python.sh",
    "generate:openapi:go": "./scripts/shell/generate-openapi-go.sh",
    "generate:openapi": "./scripts/shell/generate-openapi-python.sh && ./scripts/shell/generate-openapi-go.sh",
    "generate:openapi:gateway": "node scripts/merge-gateway-openapi.js",
    "generate:types": "./scripts/shell/generate-typescript-types.sh",
    "generate:client": "./scripts/shell/generate-python-client.sh",
    "generate:all": "./scripts/shell/generate-all-api-contracts.sh",
    "generate:grpc": "buf generate 2>/dev/null || ./scripts/shell/generate-grpc.sh"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "1.2.12",
    "@radix-ui/react-collapsible": "1.1.12",
    "oxlint-tsgolint": "0.11.4"
  },
  "devDependencies": {
    "eslint-plugin-boundaries": "5.0.1",
    "eslint-plugin-check-file": "2.1.0",
    "eslint-plugin-filenames": "1.3.2"
  }
}
