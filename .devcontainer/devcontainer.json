{
  "name": "TracerTM Development",
  "dockerComposeFile": "docker-compose.yml",
  "service": "workspace",
  "workspaceFolder": "/workspace",

  // Features - Install additional tools and runtimes
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest",
      "moby": true
    },
    "ghcr.io/devcontainers/features/github-cli:1": {
      "version": "latest"
    }
  },

  // Environment variables for hot reload and development
  "containerEnv": {
    // Python
    "PYTHONUNBUFFERED": "1",
    "PYTHONPATH": "/workspace/src",

    // Go
    "GO_ENV": "development",
    "GIN_MODE": "debug",

    // Hot reload for Vite (React) - required for Docker on macOS/Windows
    "WATCHPACK_POLLING": "true",
    "CHOKIDAR_USEPOLLING": "true",

    // Database
    "DATABASE_URL": "postgresql+asyncpg://tracertm:tracertm_password@postgres:5432/tracertm",
    "DB_HOST": "postgres",
    "DB_PORT": "5432",
    "DB_USER": "tracertm",
    "DB_PASSWORD": "tracertm_password",
    "DB_NAME": "tracertm",

    // Redis
    "REDIS_URL": "redis://redis:6379",

    // NATS
    "NATS_URL": "nats://nats:4222",

    // Temporal
    "TEMPORAL_HOST": "temporal:7233",

    // API endpoints
    "GO_BACKEND_URL": "http://go-backend:8080",
    "PYTHON_BACKEND_URL": "http://python-backend:8000",
    "VITE_API_URL": "http://localhost:4000"
  },

  // Remote environment - secrets from GitHub Codespaces or local env
  "remoteEnv": {
    "OPENAI_API_KEY": "${localEnv:OPENAI_API_KEY}",
    "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}",
    "NEO4J_PASSWORD": "${localEnv:NEO4J_PASSWORD:password}",
    "GRAFANA_ADMIN_PASSWORD": "${localEnv:GRAFANA_ADMIN_PASSWORD:admin}"
  },

  // Forward ports for all services
  "forwardPorts": [
    4000,  // Caddy gateway
    8080,  // Go backend
    8000,  // Python backend
    5173,  // Vite frontend
    5432,  // PostgreSQL
    6379,  // Redis
    7474,  // Neo4j browser
    7687,  // Neo4j bolt
    4222,  // NATS client
    8222,  // NATS monitoring
    7233,  // Temporal
    9090,  // Prometheus
    3000,  // Grafana
    9187,  // PostgreSQL exporter
    9121   // Redis exporter
  ],

  // Port labels and auto-forward behavior
  "portsAttributes": {
    "4000": {
      "label": "Gateway (Caddy)",
      "onAutoForward": "notify",
      "protocol": "http"
    },
    "8080": {
      "label": "Go Backend",
      "onAutoForward": "ignore",
      "protocol": "http"
    },
    "8000": {
      "label": "Python Backend",
      "onAutoForward": "ignore",
      "protocol": "http"
    },
    "5173": {
      "label": "Frontend (Vite)",
      "onAutoForward": "openPreview",
      "protocol": "http"
    },
    "5432": {
      "label": "PostgreSQL",
      "onAutoForward": "ignore",
      "protocol": "tcp"
    },
    "6379": {
      "label": "Redis",
      "onAutoForward": "ignore",
      "protocol": "tcp"
    },
    "7474": {
      "label": "Neo4j Browser",
      "onAutoForward": "ignore",
      "protocol": "http"
    },
    "9090": {
      "label": "Prometheus",
      "onAutoForward": "ignore",
      "protocol": "http"
    },
    "3000": {
      "label": "Grafana",
      "onAutoForward": "ignore",
      "protocol": "http"
    }
  },

  // VS Code customizations
  "customizations": {
    "vscode": {
      // Extensions to install
      "extensions": [
        // Go
        "golang.go",

        // Python
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.black-formatter",
        "charliermarsh.ruff",

        // JavaScript/TypeScript/React
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",

        // Database
        "mtxr.sqltools",
        "mtxr.sqltools-driver-pg",

        // Docker
        "ms-azuretools.vscode-docker",

        // Git
        "eamodio.gitlens",
        "github.vscode-pull-request-github",

        // YAML
        "redhat.vscode-yaml",

        // Testing
        "hbenl.vscode-test-explorer",

        // Utilities
        "streetsidesoftware.code-spell-checker",
        "editorconfig.editorconfig",
        "gruntfuggly.todo-tree",
        "usernamehw.errorlens"
      ],

      // VS Code settings
      "settings": {
        // Editor
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
          "source.fixAll.eslint": "explicit",
          "source.organizeImports": "explicit"
        },

        // Go
        "go.toolsManagement.autoUpdate": true,
        "go.useLanguageServer": true,
        "go.lintOnSave": "workspace",
        "go.formatTool": "goimports",

        // Python
        "python.defaultInterpreterPath": "/workspace/.venv/bin/python",
        "python.formatting.provider": "black",
        "python.linting.enabled": true,
        "python.linting.ruffEnabled": true,
        "python.testing.pytestEnabled": true,

        // JavaScript/TypeScript
        "typescript.tsdk": "frontend/node_modules/typescript/lib",
        "eslint.workingDirectories": [
          { "pattern": "frontend/*/" }
        ],

        // Files
        "files.exclude": {
          "**/__pycache__": true,
          "**/*.pyc": true,
          "**/node_modules": true,
          "**/.next": true,
          "**/tmp": true
        },

        // Terminal
        "terminal.integrated.defaultProfile.linux": "bash",
        "terminal.integrated.profiles.linux": {
          "bash": {
            "path": "/bin/bash"
          }
        }
      }
    }
  },

  // Lifecycle hooks
  "postCreateCommand": "bash .devcontainer/postCreate.sh",
  "postStartCommand": "echo '✅ TracerTM development container started! Run `make dev-tui` to start all services.'",

  // Mount additional volumes for caching
  "mounts": [
    // Go module cache
    "source=go-pkg-cache,target=/go/pkg,type=volume",
    // Node modules cache (prevents permission issues)
    "source=node-modules-cache,target=/workspace/frontend/node_modules,type=volume",
    // Python virtual environment cache
    "source=python-venv-cache,target=/workspace/.venv,type=volume"
  ],

  // Resource requirements for GitHub Codespaces
  "hostRequirements": {
    "cpus": 4,
    "memory": "8gb",
    "storage": "32gb"
  },

  // User settings
  "remoteUser": "vscode",
  "updateRemoteUserUID": true
}
