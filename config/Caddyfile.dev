{
    auto_https off
    admin localhost:2019
}

# Gateway :4000 - single entrypoint for external clients (frontend, MCP, CLI).
# Frontend is served via this gateway; Vite (5173) is internal-only. Use http://localhost:4000 only.
# CORS: allow only gateway origin (browser always uses :4000).
# gRPC (port 9091) is internal-only: not exposed here. Use for server-to-server only.
:4000 {
    # route preserves directive order so OPTIONS is handled first (Caddy otherwise sorts path matchers before named matchers)
    route {
        # OPTIONS preflight first – must run before any path handle so X-Bulk-Operation is allowed
        @options method OPTIONS
        handle @options {
            header Access-Control-Allow-Origin http://localhost:4000
            header Access-Control-Allow-Credentials true
            header Access-Control-Allow-Methods "GET, POST, PUT, PATCH, DELETE, OPTIONS"
            header Access-Control-Allow-Headers "Content-Type, Authorization, X-Bulk-Operation, X-Request-ID"
            header Access-Control-Max-Age 86400
            respond 204
        }

        # Health check (GET) – must return 200 for process-compose readiness_probe
        handle /health {
            header Access-Control-Allow-Origin http://localhost:4000
            header Access-Control-Allow-Credentials true
            respond "OK" 200
        }
        handle /health/ {
            header Access-Control-Allow-Origin http://localhost:4000
            header Access-Control-Allow-Credentials true
            respond "OK" 200
        }

        # Python MCP (more specific first)
        handle /api/v1/mcp/* {
            reverse_proxy localhost:8000
        }

        # Notifications API (Go backend; includes SSE stream)
        handle /api/v1/notifications {
            reverse_proxy localhost:8080
        }
        handle /api/v1/notifications/ {
            reverse_proxy localhost:8080
        }
        handle /api/v1/notifications/* {
            reverse_proxy localhost:8080
        }

        # WebSocket (Go backend) – explicit so upgrade headers are passed
        handle /api/v1/ws {
            header Access-Control-Allow-Origin http://localhost:4000
            header Access-Control-Allow-Credentials true
            header Access-Control-Allow-Methods "GET, OPTIONS"
            header Access-Control-Allow-Headers "Content-Type, Authorization, X-Request-ID, Upgrade, Connection"
            reverse_proxy localhost:8080 {
                transport http {
                    versions 1.1
                }
                header_up Connection "Upgrade"
                header_up Upgrade "websocket"
            }
        }

        # Items API (Go backend)
        handle /api/v1/items {
            reverse_proxy localhost:8080
        }
        handle /api/v1/items/* {
            reverse_proxy localhost:8080
        }

        # Go Backend API (remaining /api/v1/*)
        handle /api/v1/* {
            reverse_proxy localhost:8080
        }

        # Python Backend API
        handle /api/py/* {
            reverse_proxy localhost:8000
        }

        # Legacy WebSocket path (prefer /api/v1/ws)
        handle /ws {
            header Access-Control-Allow-Origin http://localhost:4000
            header Access-Control-Allow-Credentials true
            header Access-Control-Allow-Methods "GET, OPTIONS"
            header Access-Control-Allow-Headers "Content-Type, Authorization, X-Request-ID, Upgrade, Connection"
            reverse_proxy localhost:8080 {
                transport http {
                    versions 1.1
                }
                header_up Connection "Upgrade"
                header_up Upgrade "websocket"
            }
        }
        handle /ws/* {
            header Access-Control-Allow-Origin http://localhost:4000
            header Access-Control-Allow-Credentials true
            header Access-Control-Allow-Methods "GET, OPTIONS"
            header Access-Control-Allow-Headers "Content-Type, Authorization, X-Request-ID, Upgrade, Connection"
            reverse_proxy localhost:8080 {
                transport http {
                    versions 1.1
                }
                header_up Connection "Upgrade"
                header_up Upgrade "websocket"
            }
        }

        # API Documentation
        handle /docs* {
            reverse_proxy localhost:8080
        }

        # Prometheus (admin only; port 9090)
        handle /prometheus/* {
            reverse_proxy localhost:9090
        }

        # Grafana
        handle /grafana/* {
            reverse_proxy localhost:3000
        }

        # Doc site (Next.js docs app – process-compose service "docs" on 3001)
        handle /documentation {
            reverse_proxy localhost:3001
        }
        handle /documentation/* {
            reverse_proxy localhost:3001
        }

        # Storybook (component docs – process-compose service "storybook" on 6006)
        handle /storybook {
            reverse_proxy localhost:6006
        }
        handle /storybook/* {
            reverse_proxy localhost:6006
        }

        # Frontend (Vite dev server; bound to 127.0.0.1:5173 – internal only; use this gateway as the only dev URL)
        handle {
            reverse_proxy 127.0.0.1:5173
        }
    }

    # Logging
    log {
        output file .process-compose/logs/caddy-access.log
        format json
    }
}
