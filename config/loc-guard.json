{
  "max_loc": 500,
  "allowlist_file": "config/loc-allowlist.txt",
  "search_dirs": [
    "src",
    "backend",
    "internal",
    "frontend/apps",
    "frontend/packages",
    "cli"
  ],
  "exclude_dirs": [
    "node_modules",
    ".git",
    ".venv",
    "dist",
    "coverage",
    "playwright-report",
    "storybook-static",
    "docs",
    "ARCHIVE",
    "CONFIG",
    "test-results",
    "openapi",
    "proto"
  ],
  "exclude_paths": [
    "frontend/apps/web/src/api/schema.ts"
  ],
  "exclude_patterns": [
    "*_pb2.py",
    "*_pb2_grpc.py",
    "*.gen.ts",
    "*.generated.*",
    "*.sql.go",
    "*.d.ts",
    "*.d.mts",
    "*.d.cts",
    "routeTree.gen.ts"
  ],
  "extensions": [
    ".py",
    ".go",
    ".ts",
    ".tsx",
    ".js",
    ".jsx",
    ".mjs",
    ".cjs"
  ]
}
