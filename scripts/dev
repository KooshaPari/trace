#!/usr/bin/env python3
"""
TraceRTM Development CLI

Provides utilities for local development including:
- Service health checks
- Database seeding and management
- Cache clearing
- Log management
- Service status monitoring
"""

import os
import sys
import socket
import subprocess
import time
from pathlib import Path
from typing import Optional

import click
import psycopg2
import redis
from neo4j import GraphDatabase


# Color codes for terminal output
class Colors:
    GREEN = '\033[92m'
    RED = '\033[91m'
    YELLOW = '\033[93m'
    BLUE = '\033[94m'
    RESET = '\033[0m'
    BOLD = '\033[1m'


def print_success(message: str):
    """Print success message in green."""
    click.echo(f"{Colors.GREEN}✓ {message}{Colors.RESET}")


def print_error(message: str):
    """Print error message in red."""
    click.echo(f"{Colors.RED}✗ {message}{Colors.RESET}")


def print_warning(message: str):
    """Print warning message in yellow."""
    click.echo(f"{Colors.YELLOW}⚠ {message}{Colors.RESET}")


def print_info(message: str):
    """Print info message in blue."""
    click.echo(f"{Colors.BLUE}ℹ {message}{Colors.RESET}")


def check_port(host: str, port: int, service_name: str) -> bool:
    """Check if a service is listening on a specific port."""
    try:
        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        sock.settimeout(2)
        result = sock.connect_ex((host, port))
        sock.close()

        if result == 0:
            print_success(f"{service_name} is running on {host}:{port}")
            return True
        else:
            print_error(f"{service_name} is not reachable on {host}:{port}")
            return False
    except Exception as e:
        print_error(f"Error checking {service_name}: {e}")
        return False


def check_postgres() -> bool:
    """Check PostgreSQL connection."""
    try:
        db_url = os.getenv("DATABASE_URL", "postgresql://tracertm:password@localhost:5432/tracertm")
        conn = psycopg2.connect(db_url)
        cursor = conn.cursor()
        cursor.execute("SELECT version();")
        version = cursor.fetchone()[0]
        cursor.close()
        conn.close()
        print_success(f"PostgreSQL is running: {version.split(',')[0]}")
        return True
    except Exception as e:
        print_error(f"PostgreSQL connection failed: {e}")
        return False


def check_redis() -> bool:
    """Check Redis connection."""
    try:
        redis_url = os.getenv("REDIS_URL", "redis://localhost:6379")
        r = redis.from_url(redis_url)
        r.ping()
        info = r.info()
        print_success(f"Redis is running: v{info['redis_version']}")
        return True
    except Exception as e:
        print_error(f"Redis connection failed: {e}")
        return False


def check_neo4j() -> bool:
    """Check Neo4j connection."""
    try:
        uri = os.getenv("NEO4J_URI", "neo4j://localhost:7687")
        user = os.getenv("NEO4J_USER", "neo4j")
        password = os.getenv("NEO4J_PASSWORD", "password")

        driver = GraphDatabase.driver(uri, auth=(user, password))
        driver.verify_connectivity()

        with driver.session() as session:
            result = session.run("CALL dbms.components() YIELD versions RETURN versions[0] as version")
            version = result.single()["version"]

        driver.close()
        print_success(f"Neo4j is running: v{version}")
        return True
    except Exception as e:
        print_error(f"Neo4j connection failed: {e}")
        return False


def check_nats() -> bool:
    """Check NATS connection."""
    host = os.getenv("NATS_HOST", "localhost")
    port = int(os.getenv("NATS_PORT", "4222"))
    return check_port(host, port, "NATS")


def check_temporal() -> bool:
    """Check Temporal connection."""
    temporal_host = os.getenv("TEMPORAL_HOST", "localhost:7233")
    host, port = temporal_host.split(":")
    return check_port(host, int(port), "Temporal")


def check_minio() -> bool:
    """Check MinIO connection."""
    endpoint = os.getenv("S3_ENDPOINT", "http://localhost:9000")
    if "://" in endpoint:
        endpoint = endpoint.split("://")[1]
    host, port = endpoint.split(":")
    return check_port(host, int(port), "MinIO/S3")


@click.group()
def cli():
    """Development utilities for TraceRTM"""
    pass


@cli.command()
@click.option("--verbose", "-v", is_flag=True, help="Show detailed information")
def health(verbose: bool):
    """Check health of all services."""
    click.echo(f"\n{Colors.BOLD}=== TraceRTM Service Health Check ==={Colors.RESET}\n")

    results = {
        "PostgreSQL": check_postgres(),
        "Redis": check_redis(),
        "Neo4j": check_neo4j(),
        "NATS": check_nats(),
        "Temporal": check_temporal(),
        "MinIO/S3": check_minio(),
    }

    # Check backend services if running
    click.echo(f"\n{Colors.BOLD}Backend Services:{Colors.RESET}")
    go_port = int(os.getenv("GO_BACKEND_PORT", "8080"))
    python_port = int(os.getenv("PYTHON_BACKEND_PORT", "8000"))
    gateway_port = int(os.getenv("GATEWAY_PORT", "4000"))

    results["Go Backend"] = check_port("localhost", go_port, "Go Backend")
    results["Python Backend"] = check_port("localhost", python_port, "Python Backend")
    results["Gateway"] = check_port("localhost", gateway_port, "Gateway")

    # Summary
    healthy = sum(1 for v in results.values() if v)
    total = len(results)

    click.echo(f"\n{Colors.BOLD}Summary:{Colors.RESET}")
    if healthy == total:
        print_success(f"All services healthy ({healthy}/{total})")
        sys.exit(0)
    else:
        print_error(f"Some services are down ({healthy}/{total} healthy)")
        sys.exit(1)


@cli.command()
@click.option("--project-name", "-p", default="Demo Project", help="Project name")
@click.option("--comprehensive", "-c", is_flag=True, help="Use comprehensive seed data")
def seed(project_name: str, comprehensive: bool):
    """Seed database with test data."""
    click.echo(f"\n{Colors.BOLD}=== Seeding Database ==={Colors.RESET}\n")

    # Determine which seed script to use
    if comprehensive:
        script_path = Path(__file__).parent / "seed_comprehensive.py"
        print_info(f"Using comprehensive seed data")
    else:
        script_path = Path(__file__).parent / "seed.py"
        print_info(f"Using basic seed data")

    if not script_path.exists():
        print_error(f"Seed script not found: {script_path}")
        sys.exit(1)

    try:
        # Run the seed script
        result = subprocess.run(
            [sys.executable, str(script_path)],
            capture_output=True,
            text=True,
            env={**os.environ, "PROJECT_NAME": project_name}
        )

        if result.returncode == 0:
            print_success("Database seeded successfully!")
            if result.stdout:
                click.echo(result.stdout)
        else:
            print_error("Failed to seed database")
            if result.stderr:
                click.echo(result.stderr)
            sys.exit(1)

    except Exception as e:
        print_error(f"Error running seed script: {e}")
        sys.exit(1)


@cli.command()
@click.confirmation_option(prompt="Are you sure you want to reset the database?")
def reset():
    """Reset database (drop all tables and recreate)."""
    click.echo(f"\n{Colors.BOLD}=== Resetting Database ==={Colors.RESET}\n")

    try:
        db_url = os.getenv("DATABASE_URL", "postgresql://tracertm:password@localhost:5432/tracertm")

        # Drop all tables
        print_info("Dropping all tables...")
        conn = psycopg2.connect(db_url)
        conn.autocommit = True
        cursor = conn.cursor()

        # Drop all tables in public schema
        cursor.execute("""
            DROP SCHEMA public CASCADE;
            CREATE SCHEMA public;
            GRANT ALL ON SCHEMA public TO tracertm;
            GRANT ALL ON SCHEMA public TO public;
        """)

        cursor.close()
        conn.close()
        print_success("Database reset successfully!")

        # Run migrations
        print_info("Running migrations...")
        backend_dir = Path(__file__).parent.parent / "backend"
        result = subprocess.run(
            ["alembic", "upgrade", "head"],
            cwd=backend_dir,
            capture_output=True,
            text=True
        )

        if result.returncode == 0:
            print_success("Migrations completed successfully!")
        else:
            print_error("Migration failed")
            if result.stderr:
                click.echo(result.stderr)
            sys.exit(1)

    except Exception as e:
        print_error(f"Error resetting database: {e}")
        sys.exit(1)


@cli.command()
@click.option("--all", "-a", "clear_all", is_flag=True, help="Clear all caches")
@click.option("--redis", "-r", is_flag=True, help="Clear Redis cache")
@click.option("--neo4j", "-n", is_flag=True, help="Clear Neo4j graph data")
def clear(clear_all: bool, redis: bool, neo4j: bool):
    """Clear caches and temporary data."""
    click.echo(f"\n{Colors.BOLD}=== Clearing Caches ==={Colors.RESET}\n")

    if clear_all:
        redis = neo4j = True

    if not any([redis, neo4j]):
        print_warning("No cache specified. Use --all, --redis, or --neo4j")
        return

    # Clear Redis
    if redis:
        try:
            redis_url = os.getenv("REDIS_URL", "redis://localhost:6379")
            r = redis.from_url(redis_url)
            r.flushdb()
            print_success("Redis cache cleared")
        except Exception as e:
            print_error(f"Failed to clear Redis: {e}")

    # Clear Neo4j
    if neo4j:
        try:
            uri = os.getenv("NEO4J_URI", "neo4j://localhost:7687")
            user = os.getenv("NEO4J_USER", "neo4j")
            password = os.getenv("NEO4J_PASSWORD", "password")

            driver = GraphDatabase.driver(uri, auth=(user, password))
            with driver.session() as session:
                session.run("MATCH (n) DETACH DELETE n")
            driver.close()
            print_success("Neo4j graph data cleared")
        except Exception as e:
            print_error(f"Failed to clear Neo4j: {e}")


@cli.command()
@click.option("--service", "-s", help="Service name (go, python, gateway, all)")
@click.option("--follow", "-f", is_flag=True, help="Follow log output")
@click.option("--lines", "-n", default=50, help="Number of lines to show")
def logs(service: Optional[str], follow: bool, lines: int):
    """Tail service logs."""
    click.echo(f"\n{Colors.BOLD}=== Service Logs ==={Colors.RESET}\n")

    log_dir = Path(__file__).parent.parent / "logs"
    if not log_dir.exists():
        print_warning("Logs directory not found. Are services running?")
        return

    if service == "all" or not service:
        # Show all logs
        log_files = list(log_dir.glob("*.log"))
        if not log_files:
            print_warning("No log files found")
            return

        for log_file in log_files:
            print_info(f"\n=== {log_file.name} ===")
            with open(log_file) as f:
                lines_list = f.readlines()
                for line in lines_list[-lines:]:
                    click.echo(line.rstrip())
    else:
        # Show specific service logs
        log_file = log_dir / f"{service}.log"
        if not log_file.exists():
            print_error(f"Log file not found: {log_file}")
            return

        if follow:
            # Follow log file
            subprocess.run(["tail", "-f", str(log_file)])
        else:
            # Show last N lines
            with open(log_file) as f:
                lines_list = f.readlines()
                for line in lines_list[-lines:]:
                    click.echo(line.rstrip())


@cli.command()
def status():
    """Show detailed status of all services."""
    click.echo(f"\n{Colors.BOLD}=== TraceRTM Service Status ==={Colors.RESET}\n")

    # Check if process-compose is running
    try:
        result = subprocess.run(
            ["pgrep", "-f", "process-compose"],
            capture_output=True,
            text=True
        )

        if result.returncode == 0:
            print_success("Process Compose is running")

            # Show process status
            print_info("\nRunning processes:")
            ps_result = subprocess.run(
                ["ps", "aux"],
                capture_output=True,
                text=True
            )

            for line in ps_result.stdout.split("\n"):
                if any(svc in line for svc in ["postgres", "redis", "neo4j", "nats", "temporal", "minio"]):
                    click.echo(f"  {line}")
        else:
            print_warning("Process Compose is not running")
            print_info("Start services with: make dev")

    except Exception as e:
        print_error(f"Error checking service status: {e}")


@cli.command()
@click.option("--users", "-u", default=10, help="Number of users to generate")
@click.option("--projects", "-p", default=5, help="Number of projects to generate")
@click.option("--items", "-i", default=50, help="Number of items to generate")
def generate(users: int, projects: int, items: int):
    """Generate test data with specific counts."""
    click.echo(f"\n{Colors.BOLD}=== Generating Test Data ==={Colors.RESET}\n")

    print_info(f"Generating:")
    print_info(f"  - {users} users")
    print_info(f"  - {projects} projects")
    print_info(f"  - {items} items")

    # Create a temporary Python script to generate data
    script = f"""
import sys
from pathlib import Path
sys.path.insert(0, str(Path(__file__).parent.parent / "src"))

from datetime import datetime, timezone
from sqlalchemy import create_engine
from sqlalchemy.orm import Session
import os
import random

from tracertm.models.base import Base
from tracertm.models.project import Project
from tracertm.models.item import Item

db_url = os.getenv("DATABASE_URL", "postgresql://tracertm:password@localhost:5432/tracertm")
engine = create_engine(db_url)

with Session(engine) as session:
    # Generate projects
    for i in range({projects}):
        project = Project(
            name=f"Test Project {{i+1}}",
            description=f"Auto-generated test project {{i+1}}",
            project_metadata={{"generated": True, "index": i+1}}
        )
        session.add(project)

    session.commit()

    # Get all projects
    projects = session.query(Project).all()

    # Generate items
    item_types = ["feature", "bug", "task", "epic", "story"]
    statuses = ["todo", "in_progress", "done", "blocked"]
    priorities = ["low", "medium", "high", "critical"]

    for i in range({items}):
        project = random.choice(projects)
        item = Item(
            project_id=project.id,
            title=f"Test Item {{i+1}}",
            description=f"Auto-generated test item {{i+1}}",
            view="features",
            item_type=random.choice(item_types),
            status=random.choice(statuses),
            priority=random.choice(priorities),
            owner=f"user{{random.randint(1, {users})}}",
            item_metadata={{"generated": True, "index": i+1}}
        )
        session.add(item)

    session.commit()
    print(f"Generated {{len(projects)}} projects and {items} items")
"""

    try:
        import tempfile
        with tempfile.NamedTemporaryFile(mode='w', suffix='.py', delete=False) as f:
            f.write(script)
            script_path = f.name

        result = subprocess.run(
            [sys.executable, script_path],
            capture_output=True,
            text=True
        )

        os.unlink(script_path)

        if result.returncode == 0:
            print_success("Test data generated successfully!")
            if result.stdout:
                click.echo(result.stdout)
        else:
            print_error("Failed to generate test data")
            if result.stderr:
                click.echo(result.stderr)
            sys.exit(1)

    except Exception as e:
        print_error(f"Error generating test data: {e}")
        sys.exit(1)


@cli.command()
def init():
    """Initialize development environment."""
    click.echo(f"\n{Colors.BOLD}=== Initializing Development Environment ==={Colors.RESET}\n")

    # Check if .env exists
    env_file = Path(__file__).parent.parent / ".env"
    env_example = Path(__file__).parent.parent / ".env.example"

    if not env_file.exists() and env_example.exists():
        print_info("Creating .env from .env.example...")
        import shutil
        shutil.copy(env_example, env_file)
        print_success(".env file created")
        print_warning("Please update .env with your configuration")
    else:
        print_info(".env file already exists")

    # Check services
    print_info("\nChecking service health...")
    health.callback(verbose=False)


if __name__ == '__main__':
    cli()
