# TraceRTM Environment Configuration Template
# Copy this file to .env and fill in your values

# ============================================================================
# APPLICATION
# ============================================================================
APP_ENV=development
APP_DEBUG=true
APP_PORT=8080
APP_HOST=0.0.0.0

# ============================================================================
# DATABASE - PostgreSQL
# ============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/tracertm
DB_HOST=localhost
DB_PORT=5432
DB_USER=tracertm_user
DB_PASSWORD=your_secure_password
DB_NAME=tracertm
DB_SSL_MODE=disable
DB_MAX_CONNECTIONS=25
DB_IDLE_TIMEOUT=5m

# ============================================================================
# CACHE - Redis / Upstash
# ============================================================================
# Native Redis (optional)
REDIS_URL=redis://default:password@localhost:6379

# Upstash REST API (fallback)
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# Cache settings
CACHE_TTL=1h
CACHE_MAX_SIZE=1000

# ============================================================================
# MESSAGE QUEUE - NATS
# ============================================================================
NATS_URL=nats://localhost:4222
NATS_USER=
NATS_PASSWORD=
NATS_CLUSTER_NAME=tracertm-cluster

# ============================================================================
# GRAPH DATABASE - Neo4j
# ============================================================================
NEO4J_URI=neo4j://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password
NEO4J_DATABASE=neo4j

# ============================================================================
# SEARCH - Meilisearch
# ============================================================================
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_API_KEY=your_meilisearch_key
MEILISEARCH_INDEX_PREFIX=tracertm_

# ============================================================================
# AUTHENTICATION - WorkOS
# ============================================================================
WORKOS_API_KEY=your_workos_api_key
WORKOS_CLIENT_ID=your_workos_client_id
WORKOS_REDIRECT_URI=http://localhost:3000/auth/callback

# ============================================================================
# AUTHENTICATION - Supabase
# ============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ============================================================================
# EMBEDDINGS - OpenAI
# ============================================================================
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ============================================================================
# WORKFLOW ENGINE - Hatchet
# ============================================================================
HATCHET_API_URL=http://localhost:8080
HATCHET_API_KEY=your_hatchet_api_key
HATCHET_TENANT_ID=your_tenant_id

# ============================================================================
# FRONTEND
# ============================================================================
VITE_API_URL=http://localhost:8080
VITE_WS_URL=ws://localhost:8080
VITE_WORKOS_CLIENT_ID=your_workos_client_id
VITE_ENVIRONMENT=development

# ============================================================================
# DESKTOP APP - Tauri
# ============================================================================
TAURI_PRIVATE_KEY=your_tauri_private_key
TAURI_KEY_PASSWORD=your_tauri_key_password

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=debug
LOG_FORMAT=json
LOG_OUTPUT=stdout

# ============================================================================
# MONITORING
# ============================================================================
SENTRY_DSN=
DATADOG_API_KEY=
PROMETHEUS_PORT=9090

# ============================================================================
# DEPLOYMENT
# ============================================================================
ENVIRONMENT=development
REGION=us-east-1
DEPLOYMENT_VERSION=1.0.0

