{
  "name": "TraceRTM API Documentation",
  "entryPoints": [
    "../frontend/apps/web/src",
    "../frontend/packages/ui/src"
  ],
  "out": "./docs/api",
  "theme": "default",
  "readme": "none",
  "excludePrivate": true,
  "excludeProtected": false,
  "excludeExternals": true,
  "excludeInternal": true,
  "includeVersion": true,
  "includeDeclarations": true,
  "declaration": true,
  "declarationMap": true,
  "sourceMap": true,
  "stripInternal": true,
  "stripPrivate": true,
  "stripProtected": false,
  "hideGenerator": false,
  "hideBreadcrumbs": false,
  "hideInPageTOC": false,
  "hidePageTitle": false,
  "hidePageHeader": false,
  "hideModules": false,
  "hideSearch": false,
  "hideNavigation": false,
  "hideGroupHeadings": false,
  "hideMembersSymbol": false,
  "hideParameterTypesInTitle": false,
  "hidePropertyAccessors": false,
  "hideReflectionPageTitle": false,
  "hideSourceCode": false,
  "hideSourcePath": false,
  "hideSourcePathLinks": false,
  "hideSourcePathLinksInComments": false,
  "hideSourcePathLinksInHeaders": false,
  "hideSourcePathLinksInMemberTitles": false,
  "hideSourcePathLinksInPageTitles": false,
  "hideSourcePathLinksInReflectionTitles": false,
  "hideSourcePathLinksInTableOfContents": false,
  "hideSourcePathLinksInTypeDefinitions": false,
  "hideSourcePathLinksInTypeHeadings": false,
  "hideSourcePathLinksInTypeMembers": false,
  "hideSourcePathLinksInTypeParameters": false,
  "hideSourcePathLinksInTypeReturns": false,
  "hideSourcePathLinksInTypeThrows": false,
  "hideSourcePathLinksInTypeUnions": false,
  "hideSourcePathLinksInTypeVariances": false,
  "hideSourcePathLinksInTypeVariances": false,
  "categorizeByGroup": true,
  "categoryOrder": [
    "Components",
    "Hooks",
    "Utils",
    "Types",
    "Other"
  ],
  "sort": [
    "source-order"
  ],
  "searchInComments": true,
  "searchInDocuments": true,
  "searchInFiles": true,
  "searchInHeadings": true,
  "searchInMembers": true,
  "searchInModules": true,
  "searchInNames": true,
  "searchInPages": true,
  "searchInReflections": true,
  "searchInSignatures": true,
  "searchInTypes": true,
  "searchInVariables": true,
  "searchLimit": 20,
  "searchMinCharacters": 2,
  "searchSortStrategy": "boost",
  "searchTermBoost": 10,
  "searchCaseSensitive": false,
  "searchHighlightTerms": true,
  "searchHighlightMatches": true,
  "searchHighlightMatchesInComments": true,
  "searchHighlightMatchesInDocuments": true,
  "searchHighlightMatchesInFiles": true,
  "searchHighlightMatchesInHeadings": true,
  "searchHighlightMatchesInMembers": true,
  "searchHighlightMatchesInModules": true,
  "searchHighlightMatchesInNames": true,
  "searchHighlightMatchesInPages": true,
  "searchHighlightMatchesInReflections": true,
  "searchHighlightMatchesInSignatures": true,
  "searchHighlightMatchesInTypes": true,
  "searchHighlightMatchesInVariables": true,
  "plugin": [
    "typedoc-plugin-markdown"
  ]
}

