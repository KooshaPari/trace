{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://tracertm.io/schemas/traceability-links/v1.0.0",
  "title": "TraceRTM Traceability Links Schema",
  "description": "Schema for bidirectional traceability links between documentation and code",
  "version": "1.0.0",
  "date": "2026-02-12",
  "definitions": {
    "DocReference": {
      "type": "object",
      "description": "Reference to a documentation artifact (Epic, FR, ADR, Journey, Task)",
      "required": ["type", "id", "file", "line"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["Epic", "FR", "ADR", "Journey", "Task", "UserStory"],
          "description": "Type of documentation artifact"
        },
        "id": {
          "type": "string",
          "pattern": "^(EPIC-\\d+|FR-[A-Z]+-\\d+|ADR-\\d{4}|US-[A-Z]+-\\d+|JOURNEY-\\d+|TASK-\\d+)$",
          "description": "Unique identifier (e.g., EPIC-001, FR-DISC-001, ADR-0001)"
        },
        "file": {
          "type": "string",
          "description": "Relative path to documentation file from project root"
        },
        "line": {
          "type": "integer",
          "minimum": 1,
          "description": "Line number where artifact is defined"
        },
        "title": {
          "type": "string",
          "description": "Human-readable title of artifact"
        },
        "status": {
          "type": "string",
          "enum": ["Draft", "Proposed", "Active", "Implemented", "Deprecated", "Superseded"],
          "description": "Current status of artifact"
        }
      }
    },
    "CodeReference": {
      "type": "object",
      "description": "Reference to code artifact (Model, Service, API, Handler, Tool)",
      "required": ["type", "name", "file", "line_start"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["Model", "Service", "API", "Handler", "Tool", "Function", "Class", "Method", "Test"],
          "description": "Type of code artifact"
        },
        "name": {
          "type": "string",
          "description": "Full qualified name (e.g., GitHubImportService, POST /api/v1/integrations/github)"
        },
        "file": {
          "type": "string",
          "description": "Relative path to source file from project root"
        },
        "line_start": {
          "type": "integer",
          "minimum": 1,
          "description": "Starting line number of definition"
        },
        "line_end": {
          "type": "integer",
          "minimum": 1,
          "description": "Ending line number of definition"
        },
        "language": {
          "type": "string",
          "enum": ["python", "go", "typescript", "javascript"],
          "description": "Programming language"
        },
        "module": {
          "type": "string",
          "description": "Module or package name"
        }
      }
    },
    "LinkMetadata": {
      "type": "object",
      "description": "Metadata about the traceability link",
      "properties": {
        "created_at": {
          "type": "string",
          "format": "date-time",
          "description": "When link was created"
        },
        "created_by": {
          "type": "string",
          "enum": ["manual", "auto_discovery", "import", "webhook"],
          "description": "How link was created"
        },
        "verified": {
          "type": "boolean",
          "description": "Whether link has been manually verified"
        },
        "verified_at": {
          "type": "string",
          "format": "date-time",
          "description": "When link was last verified"
        },
        "verified_by": {
          "type": "string",
          "description": "User who verified the link"
        },
        "notes": {
          "type": "string",
          "description": "Additional context or notes"
        },
        "source_line": {
          "type": "integer",
          "description": "Exact line where reference was found (for auto-discovered links)"
        },
        "match_pattern": {
          "type": "string",
          "description": "Regex pattern that matched (for auto-discovered links)"
        }
      }
    },
    "TraceLink": {
      "type": "object",
      "description": "A bidirectional traceability link between documentation and code",
      "required": ["id", "from", "to", "linkType", "confidence"],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid",
          "description": "Unique identifier for this link"
        },
        "from": {
          "oneOf": [
            {"$ref": "#/definitions/DocReference"},
            {"$ref": "#/definitions/CodeReference"}
          ],
          "description": "Source of the link"
        },
        "to": {
          "oneOf": [
            {"$ref": "#/definitions/DocReference"},
            {"$ref": "#/definitions/CodeReference"}
          ],
          "description": "Target of the link"
        },
        "linkType": {
          "type": "string",
          "enum": [
            "traces_to",
            "implements",
            "tested_by",
            "documents",
            "depends_on",
            "supersedes",
            "relates_to",
            "refines",
            "validates"
          ],
          "description": "Type of relationship"
        },
        "confidence": {
          "type": "string",
          "enum": ["high", "medium", "low"],
          "description": "Confidence level of the link"
        },
        "auto_discovered": {
          "type": "boolean",
          "default": false,
          "description": "Whether link was automatically discovered"
        },
        "metadata": {
          "$ref": "#/definitions/LinkMetadata",
          "description": "Additional metadata about the link"
        }
      }
    }
  },
  "type": "object",
  "required": ["version", "project", "links"],
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0.0",
      "description": "Schema version"
    },
    "project": {
      "type": "object",
      "required": ["name", "id"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Project name"
        },
        "id": {
          "type": "string",
          "description": "Project identifier"
        },
        "description": {
          "type": "string",
          "description": "Project description"
        }
      }
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "When this link database was generated"
    },
    "links": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/TraceLink"
      },
      "description": "Array of traceability links"
    },
    "statistics": {
      "type": "object",
      "description": "Summary statistics about the link database",
      "properties": {
        "total_links": {
          "type": "integer",
          "minimum": 0,
          "description": "Total number of links"
        },
        "by_type": {
          "type": "object",
          "description": "Count of links by type"
        },
        "by_confidence": {
          "type": "object",
          "description": "Count of links by confidence level"
        },
        "auto_discovered_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of automatically discovered links"
        },
        "manual_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of manually created links"
        }
      }
    }
  }
}
