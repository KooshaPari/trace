{
  "// NOTE": "This is a configuration snippet for eslint-plugin-boundaries",
  "// Add to frontend/.oxlintrc.json or as a separate config file",

  "plugins": ["boundaries"],

  "rules": {
    "// Enforce single entry point": "Applications should only import from index.tsx files",
    "boundaries/entry-point": [
      "error",
      {
        "disallow": ["*"],
        "allow": ["apps/*/src/index.tsx", "apps/*/src/main.tsx"],
        "default": "disallow"
      }
    ],

    "// Restrict external imports": "Only allow specific external packages",
    "boundaries/no-external-import": [
      "error",
      {
        "allow": [
          "react",
          "react-dom",
          "@tanstack/react-router",
          "@tanstack/react-query",
          "zod",
          "tailwindcss"
        ]
      }
    ],

    "// Enforce public API imports": "Prevent importing private/internal modules",
    "boundaries/no-private-import": [
      "error",
      {
        "allow": ["src/**/*"],
        "restrict": "**/internal/**",
        "default": "disallow"
      }
    ],

    "// Element type enforcement": "Ensure elements are imported correctly",
    "boundaries/element-types": [
      "error",
      {
        "default": "disallow",
        "rules": [
          {
            "from": "components",
            "allow": ["components", "hooks", "lib", "types"]
          },
          {
            "from": "api",
            "disallow": ["components", "views", "stores"]
          },
          {
            "from": "views",
            "allow": ["components", "api", "stores", "hooks", "lib"]
          },
          {
            "from": "stores",
            "disallow": ["views", "components"]
          }
        ]
      }
    ]
  },

  "settings": {
    "boundaries/include": ["**/*.{js,jsx,ts,tsx}"],
    "boundaries/elements": [
      {
        "type": "components",
        "pattern": "components/**/*",
        "mode": "file"
      },
      {
        "type": "views",
        "pattern": "views/**/*",
        "mode": "file"
      },
      {
        "type": "api",
        "pattern": "api/**/*",
        "mode": "file"
      },
      {
        "type": "stores",
        "pattern": "stores/**/*",
        "mode": "file"
      },
      {
        "type": "hooks",
        "pattern": "hooks/**/*",
        "mode": "file"
      },
      {
        "type": "lib",
        "pattern": "lib/**/*",
        "mode": "file"
      },
      {
        "type": "types",
        "pattern": "types/**/*",
        "mode": "file"
      },
      {
        "type": "utils",
        "pattern": "utils/**/*",
        "mode": "file"
      },
      {
        "type": "internal",
        "pattern": "internal/**/*",
        "mode": "file",
        "capture": ["private"]
      }
    ]
  }
}
