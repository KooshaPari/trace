{
  "name": "tracertm-docs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:static": "next build && echo '✅ Static build complete! Open ./out/index.html in your browser'",
    "start": "next start",
    "serve:static": "cd out && python3 -m http.server 8000",
    "view:static": "open ./out/index.html",
    "lint": "next lint",
    "docs:generate": "npm run docs:ts && npm run docs:jsdoc",
    "docs:ts": "typedoc --out ./docs/api ./src --tsconfig ./tsconfig.json",
    "docs:jsdoc": "jsdoc -c jsdoc.json",
    "docs:serve": "cd docs && python3 -m http.server 8000",
    "api:generate": "bun run ../scripts/generate-api-docs.ts"
  },
  "dependencies": {
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slot": "^1.1.0",
    "@tailwindcss/typography": "^0.5.19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "framer-motion": "^11.11.17",
    "fumadocs-core": "^16.2.1",
    "fumadocs-mdx": "^14.0.4",
    "fumadocs-openapi": "^10.1.0",
    "fumadocs-ui": "^16.2.1",
    "lucide-react": "^0.555.0",
    "mermaid": "^11.12.1",
    "next": "^16.0.6",
    "react": "^19.0.0-rc-de68d2f4-20241204",
    "react-dom": "^19.0.0-rc-de68d2f4-20241204",
    "react-icons": "^5.5.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "remark-mermaid": "^0.2.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.1",
    "autoprefixer": "^10.4.22",
    "jsdoc": "^4.0.5",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.0",
    "typedoc": "^0.28.15",
    "typescript": "^5.7.2"
  }
}
