      'v2-0-features': { title: 'v2.0 Features', path: '01a-v2.0-features' },
      'v2-0-breaking': { title: 'v2.0 Breaking Changes', path: '01b-v2.0-breaking' },
      'v2-0-migration': { title: 'v2.0 Migration Guide', path: '01c-v2.0-migration' },
      'v1-5': { title: 'v1.5', path: '02-v1.5' },
      'v1-5-features': { title: 'v1.5 Features', path: '02a-v1.5-features' },
      'v1-5-bugfixes': { title: 'v1.5 Bug Fixes', path: '02b-v1.5-bugfixes' },
      'v1-4': { title: 'v1.4', path: '03-v1.4' },
      'v1-4-features': { title: 'v1.4 Features', path: '03a-v1.4-features' },
      'v1-3': { title: 'v1.3', path: '04-v1.3' },
      'v1-2': { title: 'v1.2', path: '05-v1.2' },
      'v1-1': { title: 'v1.1', path: '06-v1.1' },
      'v1-0': { title: 'v1.0', path: '07-v1.0' },
      'v1-0-initial': { title: 'v1.0 Initial Release', path: '07a-v1.0-initial' },
      'roadmap': { title: 'Roadmap', path: '08-roadmap' },
      'upcoming': { title: 'Upcoming Features', path: '08a-upcoming' },
    },
  },
}

const STORAGE_KEY = 'tracertm-docs-expanded-sections'

function getDocPath(slug?: string[]): { path: string; title: string } | null {
  if (!slug || slug.length === 0) {
    return null
  }

  let current: any = DOCS_STRUCTURE
  let pathParts: string[] = []
  let title = ''

  for (let i = 0; i < slug.length; i++) {
    const segment = slug[i]
    if (current[segment]) {
      const item = current[segment]
      pathParts.push(item.path)
      title = item.title
      current = item.children || {}
    } else {
      return null
    }
  }

  const filePath = join(process.cwd(), 'content', 'docs', ...pathParts, 'index.mdx')
  return { path: filePath, title }
}

function getDocContent(slug?: string[]) {
  const docPath = getDocPath(slug)
  if (!docPath) {
    return null
  }

  try {
    if (!existsSync(docPath.path)) {
      return null
    }
    const content = readFileSync(docPath.path, 'utf-8')

    // Parse frontmatter
    const frontmatterMatch = content.match(/^---\n([\s\S]*?)\n---\n([\s\S]*)$/)
    if (frontmatterMatch) {
      const frontmatter = frontmatterMatch[1]
      const body = frontmatterMatch[2]
      const titleMatch = frontmatter.match(/title:\s*['"]?([^'"]+)['"]?/)
      const title = titleMatch ? titleMatch[1] : docPath.title
      return { title, body }
    }

    return { title: docPath.title, body: content }
  } catch (error) {
    console.error(`Failed to load doc: ${slug?.join('/')}`, error)
    return null
  }
}

export function generateStaticParams() {
  const params: { slug: string[] }[] = [{ slug: [] }]

  function collectPaths(items: any, path: string[] = []) {
    Object.entries(items).forEach(([key, value]: [string, any]) => {
      const newPath = [...path, key]
      params.push({ slug: newPath })
      if (value.children) {
        collectPaths(value.children, newPath)
      }
    })
  }

  collectPaths(DOCS_STRUCTURE)
  return params
}

function getIconComponent(iconName?: string) {
  const iconMap: { [key: string]: any } = {
    'Rocket': Rocket,
    'BookOpen': BookOpen,
    'Zap': Zap,
    'Wrench': Wrench,
    'RotateCcw': RotateCcw,
    'FileText': FileText,
  }
  return iconMap[iconName || ''] || null
}

// Helper to get the path to a section as a string
function getPathString(path: string[]): string {
  return path.join('/')
}

// Helper to check if a path is in the active path
function isPathInActivePath(sectionPath: string[], currentPath?: string[]): boolean {
  if (!currentPath || currentPath.length === 0) return false
  return currentPath.slice(0, sectionPath.length).join('/') === sectionPath.join('/')
}

// Collapsible nav item component
function NavItem({
  itemKey,
  value,
  path,
  depth,
  currentSlug,
  expandedSections,
  toggleSection
}: {
  itemKey: string
  value: any
  path: string[]
  depth: number
  currentSlug?: string[]
  expandedSections: Set<string>
  toggleSection: (path: string) => void
}) {
  const newPath = [...path, itemKey]
  const pathString = getPathString(newPath)
  const isActive = currentSlug?.join('/') === pathString
  const isInActivePath = isPathInActivePath(newPath, currentSlug)
  const hasChildren = value.children && Object.keys(value.children).length > 0
  const isExpanded = expandedSections.has(pathString)
  const IconComponent = depth === 0 ? getIconComponent(value.icon) : null

  return (
    <div>
      <div className="flex items-center gap-1">
        {hasChildren && (
          <button
            onClick={(e) => {
              e.preventDefault()
              e.stopPropagation()
              toggleSection(pathString)
            }}
            className="p-1 hover:bg-muted rounded transition-colors"
            aria-label={isExpanded ? 'Collapse section' : 'Expand section'}
          >
            {isExpanded ? (
              <ChevronDown className="w-4 h-4 text-muted-foreground" />
            ) : (
              <ChevronRight className="w-4 h-4 text-muted-foreground" />
            )}
          </button>
        )}
        <Link
          href={`/docs/${pathString}/`}
          className={`flex-1 flex items-center gap-2 px-3 py-2 rounded-md transition-all text-sm ${
            isActive
              ? 'bg-primary text-primary-foreground font-semibold'
              : isInActivePath
              ? 'text-primary font-medium'
              : 'hover:bg-muted'
          }`}
          style={{
            paddingLeft: hasChildren ? '8px' : `${12 + depth * 16}px`,
            marginLeft: hasChildren ? '0' : '28px'
          }}
        >
          {IconComponent && <IconComponent className="w-4 h-4 flex-shrink-0" />}
          <span className="flex-1">{value.title}</span>
        </Link>
      </div>
      {hasChildren && isExpanded && (
        <div
          className="ml-4 border-l border-muted pl-2 space-y-1 animate-in slide-in-from-top-2 duration-200"
        >
          {Object.entries(value.children).map(([childKey, childValue]: [string, any]) => (
            <NavItem
              key={childKey}
              itemKey={childKey}
              value={childValue}
              path={newPath}
              depth={depth + 1}
              currentSlug={currentSlug}
              expandedSections={expandedSections}
              toggleSection={toggleSection}
            />
          ))}
        </div>
      )}
    </div>
  )
}

// Main sidebar navigation component
function SidebarNav({ slug }: { slug?: string[] }) {
  // Load expanded sections from sessionStorage
  const [expandedSections, setExpandedSections] = useState<Set<string>>(() => {
    if (typeof window === 'undefined') return new Set()
    try {
      const stored = sessionStorage.getItem(STORAGE_KEY)
      return stored ? new Set(JSON.parse(stored)) : new Set()
    } catch {
      return new Set()
    }
  })

  // Auto-expand the path to the active page on mount and when slug changes
  useEffect(() => {
    if (!slug || slug.length === 0) return

    const pathsToExpand = new Set<string>()
    let currentPath: string[] = []

    // Build up the path segments and add each one
    slug.forEach((segment) => {
      currentPath.push(segment)
      // Expand all parent sections in the active path
      const pathString = getPathString(currentPath)
      pathsToExpand.add(pathString)
    })

    setExpandedSections((prev) => {
      const newSet = new Set([...prev, ...pathsToExpand])
      // Persist to sessionStorage
      try {
        sessionStorage.setItem(STORAGE_KEY, JSON.stringify([...newSet]))
      } catch (e) {
        console.error('Failed to save expanded sections:', e)
      }
      return newSet
    })
  }, [slug])

  const toggleSection = (path: string) => {
    setExpandedSections((prev) => {
      const newSet = new Set(prev)
      if (newSet.has(path)) {
        newSet.delete(path)
      } else {
        newSet.add(path)
      }
      // Persist to sessionStorage
      try {
        sessionStorage.setItem(STORAGE_KEY, JSON.stringify([...newSet]))
      } catch (e) {
        console.error('Failed to save expanded sections:', e)
      }
      return newSet
    })
  }

  return (
    <nav className="p-4 space-y-1">
      {Object.entries(DOCS_STRUCTURE).map(([key, value]: [string, any]) => (
        <NavItem
          key={key}
          itemKey={key}
          value={value}
          path={[]}
          depth={0}
          currentSlug={slug}
          expandedSections={expandedSections}
          toggleSection={toggleSection}
        />
      ))}
    </nav>
  )
}

// Main docs page component
export default function DocsPage({ params }: { params: Promise<{ slug?: string[] }> }) {
  const [resolvedParams, setResolvedParams] = useState<{ slug?: string[] } | null>(null)

  useEffect(() => {
    params.then(setResolvedParams)
  }, [params])

  if (!resolvedParams) {
    return null
  }

  const docContent = getDocContent(resolvedParams.slug)

  return (
    <div className="flex h-screen">
      {/* Sidebar */}
      <aside className="w-80 border-r bg-muted/50 overflow-y-auto">
        <div className="sticky top-0 bg-background border-b p-4 z-10">
          <Link href="/docs/" className="flex items-center gap-2 font-bold text-lg hover:opacity-75 transition-opacity">
            <BookOpen className="w-5 h-5" />
            TraceRTM Docs
          </Link>
        </div>
        <SidebarNav slug={resolvedParams.slug} />
      </aside>

      {/* Main Content */}
      <main className="flex-1 overflow-y-auto">
        <div className="max-w-4xl mx-auto p-8">
          {docContent ? (
            <>
              <h1 className="text-4xl font-bold mb-4">{docContent.title}</h1>
              <div className="prose prose-sm max-w-none dark:prose-invert">
                <MarkdownContent content={docContent.body} />
              </div>
            </>
          ) : (
            <>
              <h1 className="text-4xl font-bold mb-4">Documentation</h1>
              <p className="text-lg text-muted-foreground mb-8">
                Select a topic from the sidebar to get started.
              </p>
              <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                {Object.entries(DOCS_STRUCTURE).map(([key, value]: [string, any]) => {
                  const IconComponent = getIconComponent(value.icon)
                  return (
                    <Link
                      key={key}
                      href={`/docs/${key}/`}
                      className="p-4 border rounded-lg hover:border-primary hover:bg-muted transition-colors"
                    >
                      <div className="flex items-center gap-2 mb-2">
                        {IconComponent && <IconComponent className="w-5 h-5 text-primary" />}
                        <h3 className="font-semibold">{value.title}</h3>
                      </div>
                      <p className="text-sm text-muted-foreground">{value.description}</p>
                    </Link>
                  )
                })}
              </div>
            </>
          )}
        </div>
      </main>
    </div>
  )
}

// Custom components for markdown rendering
const MarkdownComponents: Components = {
  h1: ({ children }) => (
    <h1 className="text-4xl font-bold mt-8 mb-4 text-foreground">{children}</h1>
  ),
  h2: ({ children }) => (
    <h2 className="text-3xl font-bold mt-8 mb-4 text-foreground border-b pb-2">{children}</h2>
  ),
  h3: ({ children }) => (
    <h3 className="text-2xl font-semibold mt-6 mb-3 text-foreground">{children}</h3>
  ),
  h4: ({ children }) => (
    <h4 className="text-xl font-semibold mt-4 mb-2 text-foreground">{children}</h4>
  ),
  p: ({ children }) => (
    <p className="text-base leading-7 mb-4 text-foreground/90">{children}</p>
  ),
  ul: ({ children }) => (
    <ul className="list-disc list-inside space-y-2 mb-4 ml-4">{children}</ul>
  ),
  ol: ({ children }) => (
    <ol className="list-decimal list-inside space-y-2 mb-4 ml-4">{children}</ol>
  ),
  li: ({ children }) => (
    <li className="text-base text-foreground/90">{children}</li>
  ),
  code: ({ children, className }) => {
    // Check if this is a mermaid code block
    if (className?.includes('language-mermaid')) {
      return <MermaidRenderer chart={String(children).trim()} />
    }
    return (
      <code className="bg-muted px-2 py-1 rounded text-sm font-mono text-foreground">{children}</code>
    )
  },
  pre: ({ children }) => (
    <pre className="bg-muted p-4 rounded-lg overflow-x-auto mb-4">{children}</pre>
  ),
  blockquote: ({ children }) => (
    <blockquote className="border-l-4 border-primary pl-4 py-2 mb-4 italic text-foreground/75">{children}</blockquote>
  ),
  a: ({ href, children }) => (
    <a href={href} className="text-primary hover:underline">{children}</a>
  ),
  table: ({ children }) => (
    <table className="w-full border-collapse border border-muted mb-4">{children}</table>
  ),
  th: ({ children }) => (
    <th className="border border-muted bg-muted p-2 text-left font-semibold">{children}</th>
  ),
  td: ({ children }) => (
    <td className="border border-muted p-2">{children}</td>
  ),
  hr: () => <hr className="my-8 border-muted" />,
}

function MarkdownContent({ content }: { content: string }) {
  return (
    <ReactMarkdown
      remarkPlugins={[remarkGfm]}
      components={MarkdownComponents}
    >
      {content}
    </ReactMarkdown>
  )
}
