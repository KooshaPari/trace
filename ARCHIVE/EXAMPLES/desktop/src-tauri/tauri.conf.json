{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TraceRTM",
  "version": "0.1.0",
  "identifier": "com.tracertm.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": ["dmg", "msi", "deb", "appimage"],
    "createUpdaterArtifacts": true,
    "publisher": "TraceRTM Team",
    "copyright": "Copyright (c) 2024 TraceRTM Team",
    "category": "DeveloperTool",
    "shortDescription": "Requirements Traceability Matrix Management",
    "longDescription": "TraceRTM is a modern, offline-first requirements traceability management tool for software development teams.",
    "macOS": {
      "minimumSystemVersion": "10.15",
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null,
      "entitlements": null
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "wix": {
        "language": ["en-US"],
        "template": null
      },
      "nsis": {
        "compressionLevel": "high",
        "displayLanguageSelector": false,
        "installerIcon": null,
        "installMode": "perUser",
        "languages": ["en-US"],
        "template": null
      }
    },
    "linux": {
      "deb": {
        "depends": []
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  },
  "app": {
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:* https://api.tracertm.dev; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' 'unsafe-eval'",
      "dangerousDisableAssetCspModification": false
    },
    "windows": [
      {
        "title": "TraceRTM",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false,
        "center": true,
        "skipTaskbar": false,
        "theme": "Auto",
        "titleBarStyle": "Transparent"
      }
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEUwQzVGMjBGRTA5QzQxQzIKUldSeHFGZGlUcnBhYjhkVlBWVGt4UXN0OUNFQWYwNWFxb2RueWJhQ1Vsa1FpclVDdmEyN2hXNAo=",
      "endpoints": [
        "https://api.tracertm.dev/updates/{{target}}/{{current_version}}"
      ],
      "windows": {
        "installMode": "passive"
      }
    },
    "deepLink": {
      "mobile": [],
      "desktop": {
        "schemes": ["tracertm"]
      }
    }
  }
}
