{
  "name": "tracertm",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.1.38",
  "workspaces": [
    "frontend",
    "frontend/apps/*",
    "frontend/packages/*"
  ],
  "scripts": {
    "postinstall": "bash scripts/setup-typescript-wrapper.sh",
    "dev": "bun --filter='@tracertm/web' run dev",
    "build": "bun run build:frontend",
    "build:frontend": "cd frontend && bun run build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "typecheck": "cd frontend && bun run typecheck",
    "test": "bun --filter='@tracertm/web' run test",
    "test:e2e": "cd frontend/apps/web && bun run test:e2e",
    "clean": "rm -rf node_modules frontend/node_modules frontend/apps/*/node_modules frontend/packages/*/node_modules",
    "clean:build": "rm -rf frontend/apps/*/dist frontend/apps/*/.vinxi frontend/packages/*/dist"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.8",
    "@playwright/test": "^1.57.0",
    "@tanstack/router-generator": "1.139.14",
    "@types/bun": "^1.3.3",
    "@types/node": "^22.10.2",
    "oxlint": "^0.16.2",
    "typescript": "npm:@typescript/native-preview@7.0.0-dev.20251201.1"
  },
  "resolutions": {
    "@tanstack/react-router": "1.139.14",
    "@tanstack/router-core": "1.139.14",
    "@tanstack/router-plugin": "1.139.14",
    "@tanstack/router-utils": "1.139.0",
    "@tanstack/virtual-file-routes": "1.139.0",
    "@tanstack/react-start": "1.139.14",
    "@tanstack/start-plugin-core": "1.139.14",
    "@tanstack/start-server-core": "1.139.14",
    "@tanstack/start-client-core": "1.139.14",
    "@tanstack/server-functions-plugin": "1.139.0",
    "@tanstack/directive-functions-plugin": "1.139.0"
  }
}
